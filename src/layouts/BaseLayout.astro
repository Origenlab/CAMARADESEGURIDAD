---
import '@/styles/global.css';
import { SITE } from '@/consts';
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import WhatsAppFloat from '@components/WhatsAppFloat.astro';

interface FaqEntry {
  q: string;
  a: string;
}
interface ServiceEntry {
  name: string;
  description: string;
  url?: string;
}
interface ReviewEntry {
  author: string;
  rating: number;
  body: string;
  datePublished?: string;
}
interface BreadcrumbEntry {
  name: string;
  url: string;
}

interface HowToStepEntry {
  name: string;
  text: string;
  url?: string;
}
interface HowToEntry {
  name: string;
  description: string;
  totalTime?: string;
  steps: HowToStepEntry[];
}
interface ContactPointEntry {
  contactType: string;
  telephone?: string;
  email?: string;
  areaServed?: string | string[];
  availableLanguage?: string | string[];
  hoursAvailable?: string;
}
interface PlaceEntry {
  name: string;
  type?: 'AdministrativeArea' | 'City' | 'State' | 'Country';
  containedInPlace?: string;
}
interface ProductEntry {
  name: string;
  description: string;
  price?: number;
  priceCurrency?: string;
  brand?: string;
  category?: string;
  sku?: string;
  url?: string;
  image?: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string;
  showWhatsApp?: boolean;
  // Schemas opcionales
  faq?: FaqEntry[];
  services?: ServiceEntry[];
  reviews?: ReviewEntry[];
  breadcrumb?: BreadcrumbEntry[];
  howTo?: HowToEntry;
  contactPoints?: ContactPointEntry[];
  places?: PlaceEntry[];
  products?: ProductEntry[];
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description,
  image,
  canonical,
  noindex,
  type,
  publishedTime,
  modifiedTime,
  keywords,
  showWhatsApp = true,
  faq,
  services,
  reviews,
  breadcrumb,
  howTo,
  contactPoints,
  places,
  products,
  articleAuthor,
  articleSection,
  articleTags,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <SEO
      title={title}
      description={description}
      image={image}
      canonical={canonical}
      noindex={noindex}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      keywords={keywords}
      faq={faq}
      services={services}
      reviews={reviews}
      breadcrumb={breadcrumb}
      howTo={howTo}
      contactPoints={contactPoints}
      places={places}
      products={products}
      articleAuthor={articleAuthor}
      articleSection={articleSection}
      articleTags={articleTags}
    />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[60] focus:rounded-lg focus:bg-accent-500 focus:px-4 focus:py-2 focus:text-white"
      >Saltar al contenido</a
    >

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    {showWhatsApp && <WhatsAppFloat />}
  </body>
</html>
