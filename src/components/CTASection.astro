---
import { SITE } from '@config/site';
---

<section id="contacto" class="section-cream">
  <div class="container">
    <div class="overflow-hidden rounded-2xl bg-cream-50 shadow-card">
      <div class="grid lg:grid-cols-[1.3fr_1fr]">
        <!-- Lado izquierdo: copy sobre cream -->
        <div class="p-8 sm:p-12 lg:p-16">
          <span class="eyebrow">Asesoría sin compromiso</span>
          <h2 class="heading-lg mt-4 text-balance">
            ¿Listo para proteger
            <span class="text-accent-500">lo que más importa</span>?
          </h2>
          <span class="marker-line mt-5"></span>
          <p class="lead mt-6">
            Cuéntanos tu caso y en menos de 24 horas te enviamos una propuesta a tu medida —
            equipos, instalación y soporte incluidos. Respuesta por WhatsApp en menos de 15 minutos.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent('Hola, quiero una cotización personalizada.')}`}
              target="_blank"
              rel="noopener"
              class="btn-primary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path
                  d="M20.5 3.5A11.4 11.4 0 0 0 12.3 0C5.9 0 .7 5.2.7 11.6c0 2 .5 4 1.5 5.8L0 24l6.8-1.8a11.6 11.6 0 0 0 5.5 1.4h.1c6.4 0 11.6-5.2 11.6-11.6 0-3.1-1.2-6-3.4-8.3Z"
                ></path>
              </svg>
              Cotizar por WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`} class="btn-outline">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.55 19.55 0 0 1-6-6 19.86 19.86 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72a2 2 0 0 1 1.72 2.01Z"
                ></path>
              </svg>
              Llamar ahora
            </a>
          </div>
        </div>

        <!-- Lado derecho: bloque teal sólido con datos de contacto -->
        <div class="bg-brand-500 p-8 text-cream-50 sm:p-12 lg:p-16">
          <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-accent-400">
            Datos directos
          </p>
          <span class="mt-3 block h-[3px] w-12 bg-accent-500 rounded-full"></span>

          <ul class="mt-8 space-y-6">
            <li>
              <p class="text-[11px] font-bold uppercase tracking-wider text-cream-200">
                WhatsApp
              </p>
              <a
                href={`https://wa.me/${SITE.contact.whatsapp}`}
                target="_blank"
                rel="noopener"
                class="mt-1 block font-display text-lg font-black text-white hover:text-accent-400"
              >
                {SITE.contact.whatsappDisplay}
              </a>
            </li>
            <li>
              <p class="text-[11px] font-bold uppercase tracking-wider text-cream-200">
                Teléfono
              </p>
              <a
                href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`}
                class="mt-1 block font-display text-lg font-black text-white hover:text-accent-400"
              >
                {SITE.contact.phone}
              </a>
            </li>
            <li>
              <p class="text-[11px] font-bold uppercase tracking-wider text-cream-200">
                Correo
              </p>
              <a
                href={`mailto:${SITE.contact.email}`}
                class="mt-1 block font-display text-base font-black text-white hover:text-accent-400 break-all"
              >
                {SITE.contact.email}
              </a>
            </li>
            <li>
              <p class="text-[11px] font-bold uppercase tracking-wider text-cream-200">
                Horario
              </p>
              <p class="mt-1 font-display text-base font-black text-white">
                {SITE.contact.hours}
              </p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
