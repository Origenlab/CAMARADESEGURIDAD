---
import type { CollectionEntry } from 'astro:content';

interface Props {
  servicios: CollectionEntry<'servicios'>[];
}

const { servicios } = Astro.props;

const icons: Record<string, string> = {
  home: '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  store:
    '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/><path d="M9 13a3 3 0 1 0 6 0"/>',
  factory:
    '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/><path d="M7 17h2M11 17h2M15 17h2"/>',
  lock: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
  camera:
    '<path d="M3 8a2 2 0 0 1 2-2h3l2-2h4l2 2h3a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z"/><circle cx="12" cy="13" r="4"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>',
};

const fmtPrecio = (n?: number) =>
  n
    ? new Intl.NumberFormat('es-MX', {
        style: 'currency',
        currency: 'MXN',
        maximumFractionDigits: 0,
      }).format(n)
    : 'Cotizar';
---

<section id="listado" class="section-cream">
  <div class="container">
    <div class="grid items-end gap-8 lg:grid-cols-[1fr_2fr] lg:gap-16">
      <div>
        <span class="eyebrow">Nuestros servicios</span>
        <h2 class="heading-lg mt-4 text-balance">
          Cuatro líneas de
          <span class="text-accent-500">trabajo profesional</span>.
        </h2>
        <span class="marker-line mt-5"></span>
      </div>
      <p class="lead">
        Cada servicio está pensado para un contexto específico — no es el mismo sistema para una
        casa que para una nave industrial. Selecciona el que aplica a tu caso para ver paquetes,
        precios de referencia y especificaciones.
      </p>
    </div>

    <div class="mt-14 grid gap-8 lg:gap-10">
      {
        servicios
          .sort((a, b) => a.data.orden - b.data.orden)
          .map((s, i) => {
            const isBrand = s.data.color === 'brand';
            const headerBg = isBrand ? 'bg-brand-500' : 'bg-accent-500';
            const reverse = i % 2 === 1;
            return (
              <article class="card grid overflow-hidden lg:grid-cols-2">
                {/* Visual / header */}
                <div class={`${headerBg} ${reverse ? 'lg:order-2' : ''} flex flex-col justify-between p-8 lg:p-10`}>
                  <div>
                    <span class="grid h-16 w-16 place-items-center rounded-lg bg-white/15">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="h-8 w-8 text-white"
                        aria-hidden="true"
                        set:html={icons[s.data.icon]}
                      />
                    </span>
                    <p class="mt-6 text-[10px] font-bold uppercase tracking-[0.22em] text-white/80">
                      {s.data.eyebrow}
                    </p>
                    <h3 class="mt-2 font-display text-3xl font-black leading-tight text-white sm:text-4xl">
                      {s.data.title}
                    </h3>
                    <p class="mt-4 text-[15px] leading-relaxed text-white/85">
                      {s.data.subtitle}
                    </p>
                  </div>

                  {s.data.idealPara.length > 0 && (
                    <div class="mt-8 border-t border-white/15 pt-6">
                      <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-white/70">
                        Ideal para
                      </p>
                      <ul class="mt-3 space-y-1.5 text-[14px] text-white/90">
                        {s.data.idealPara.slice(0, 4).map((item) => (
                          <li class="flex items-start gap-2">
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="3"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              class="mt-1 h-3.5 w-3.5 shrink-0"
                              aria-hidden="true"
                            >
                              <path d="M20 6 9 17l-5-5" />
                            </svg>
                            <span>{item}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>

                {/* Paquetes + CTA */}
                <div class={`${reverse ? 'lg:order-1' : ''} flex flex-col bg-white p-8 lg:p-10`}>
                  <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-accent-500">
                    ● Paquetes
                  </p>
                  <ul class="mt-5 flex-1 space-y-3">
                    {s.data.paquetes.map((p) => (
                      <li class={`rounded-lg border-2 p-4 transition-colors ${p.popular ? 'border-accent-500 bg-accent-50' : 'border-cream-200 hover:border-brand-500'}`}>
                        <div class="flex items-start justify-between gap-4">
                          <div class="min-w-0">
                            <div class="flex items-center gap-2">
                              <p class="font-display text-base font-black text-brand-500">
                                {p.name}
                              </p>
                              {p.popular && (
                                <span class="rounded-full bg-accent-500 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white">
                                  Popular
                                </span>
                              )}
                            </div>
                            <p class="mt-1 text-[13px] leading-relaxed text-ink-600">
                              {p.detail}
                            </p>
                          </div>
                          <p class="shrink-0 text-right font-display text-lg font-black text-accent-500 lg:text-xl">
                            {fmtPrecio(p.precio)}
                          </p>
                        </div>
                      </li>
                    ))}
                  </ul>

                  <div class="mt-7 flex flex-wrap gap-3">
                    <a
                      href="#contacto"
                      class="btn-primary"
                    >
                      Cotizar este servicio
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="h-4 w-4"
                        aria-hidden="true"
                      >
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                      </svg>
                    </a>
                    <a
                      href={`/servicios/${s.id.replace(/\.md$/, '')}/`}
                      class="btn-outline"
                    >
                      Ver detalle completo
                    </a>
                  </div>
                </div>
              </article>
            );
          })
      }
    </div>
  </div>
</section>
