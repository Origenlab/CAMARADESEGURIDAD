---
/**
 * Hero secundario para páginas internas (L2 +).
 * Mismo lenguaje visual que el Hero del Home pero más compacto.
 * Incluye breadcrumb integrado.
 */

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  eyebrow: string;
  title: string;
  highlight?: string;
  subtitle?: string;
  breadcrumb?: BreadcrumbItem[];
  showRecBadge?: boolean;
}

const {
  eyebrow,
  title,
  highlight,
  subtitle,
  breadcrumb = [],
  showRecBadge = false,
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-cream-100"
  aria-labelledby="page-hero-title"
>
  {
    showRecBadge && (
      <div class="absolute right-4 top-4 z-20 lg:right-8 lg:top-8">
        <span class="rec-badge">REC · Sistema activo</span>
      </div>
    )
  }

  <!-- Bloque marino decorativo derecho -->
  <div
    class="absolute right-0 top-0 -z-0 hidden h-full w-1/4 bg-brand-500 lg:block"
    aria-hidden="true"
  ></div>
  <div
    class="absolute right-1/4 top-0 -z-0 hidden h-full w-1 bg-accent-500 lg:block"
    aria-hidden="true"
  ></div>

  <div class="container relative py-14 sm:py-16 lg:py-20">
    <!-- Breadcrumb visible -->
    {
      breadcrumb.length > 0 && (
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex flex-wrap items-center gap-2 text-[13px] font-semibold text-ink-600">
            {breadcrumb.map((item, i) => (
              <li class="flex items-center gap-2">
                {i > 0 && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-3.5 w-3.5 text-accent-500"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                )}
                {i === breadcrumb.length - 1 ? (
                  <span class="text-brand-500" aria-current="page">
                    {item.name}
                  </span>
                ) : (
                  <a href={item.url} class="text-ink-600 hover:text-accent-500">
                    {item.name}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="grid items-end gap-10 lg:grid-cols-[1.6fr_1fr] lg:gap-16">
      <div class="animate-fade-up">
        <span class="eyebrow">{eyebrow}</span>

        <h1 id="page-hero-title" class="heading-lg mt-5 text-balance">
          {highlight ? (
            <>
              {title.split(highlight)[0]}
              <span class="text-accent-500">{highlight}</span>
              {title.split(highlight)[1] ?? ''}
            </>
          ) : (
            title
          )}
        </h1>

        <span class="marker-line mt-5"></span>

        {
          subtitle && (
            <p class="mt-5 max-w-3xl text-[17px] leading-relaxed text-ink-700">
              {subtitle}
            </p>
          )
        }
      </div>

      <slot name="aside" />
    </div>
  </div>
</section>
