---
/**
 * Hero principal del sitio — parametrizado.
 * Por default renderiza el contenido del Home (L1).
 * Páginas internas (L2+) lo reusan con props personalizados.
 *
 * Estructura siempre igual:
 * - REC badge flotante (opcional)
 * - Línea decorativa vertical
 * - Bicolumna: col1 eyebrow + título + descripción · col2 título + 2 párrafos
 * - Strip inferior con quick-links sobre marino (opcional)
 */

interface ParagraphEntry {
  html: string;
}

interface FeatureEntry {
  text: string;
}

interface HighlightStat {
  value: string;
  label: string;
}

interface QuickLinkEntry {
  href: string;
  title: string;
  sub: string;
  icon: string;
}

interface Props {
  // Columna 1
  eyebrow?: string;
  preTitle?: string;
  title1?: string;
  title2?: string;
  subtitle?: string;
  descriptionHtml?: string;

  // Columna 2
  col2Eyebrow?: string;
  col2Title?: string;
  col2TitleHighlight?: string;
  col2Paragraphs?: ParagraphEntry[];
  col2HighlightStat?: HighlightStat;
  col2Features?: FeatureEntry[];
  col2TrustStrip?: string[];

  // Quick links strip (override del default · pasa array vacío para esconder)
  quickLinks?: QuickLinkEntry[];

  // Opciones
  showRecBadge?: boolean;
  showQuickLinks?: boolean;
}

const {
  eyebrow = 'CAMSEG · 50+ AÑOS · COBERTURA NACIONAL',
  preTitle = 'CAMSEG · Empresa mexicana de',
  title1 = 'Cámaras de',
  title2 = 'Seguridad',
  subtitle = 'para hogar, comercio, industria y gobierno.',
  descriptionHtml = `<strong class="font-bold text-brand-500">CAMSEG</strong> es la empresa mexicana líder en venta
e instalación profesional de cámaras de seguridad CCTV con
<strong class="font-bold text-brand-500">más de 50 años</strong> de experiencia y
<strong class="font-bold text-brand-500">cobertura en toda la República Mexicana</strong>.
Más de <strong class="font-bold text-brand-500">17,000 proyectos entregados</strong> con
equipos certificados <strong class="font-bold text-brand-500">Hikvision</strong>,
<strong class="font-bold text-brand-500">Dahua</strong>,
<strong class="font-bold text-brand-500">Axis</strong> y
<strong class="font-bold text-brand-500">Provision-ISR</strong> — las mismas marcas
que usan bancos, aeropuertos, plantas industriales y dependencias de gobierno.`,

  col2Eyebrow = 'Por qué CAMSEG',
  col2Title = 'Cinco décadas instalando seguridad ',
  col2TitleHighlight = 'real',
  col2Paragraphs = [
    {
      html: `<strong class="font-bold text-brand-500">CAMSEG nació en 1976</strong> como
empresa familiar mexicana especializada en sistemas de videovigilancia profesional. Cinco décadas
después somos uno de los <strong class="font-bold text-brand-500">integradores CCTV con más experiencia
del país</strong>, con técnicos certificados por fabricante y proyectos activos en residencial,
comercial, industrial y sector gobierno. Cada proyecto arranca con visita técnica gratuita,
diseño formal con plano de cobertura y propuesta cerrada por escrito — sin sorpresas, sin venta
agresiva.`,
    },
    {
      html: `<strong class="font-bold text-brand-500">Nuestro servicio no termina en la instalación.</strong>
Configuramos la app oficial en hasta cuatro dispositivos, capacitamos a tu personal y respondemos
por WhatsApp en menos de 15 minutos. Ofrecemos
<strong class="font-bold text-brand-500">garantía de 2 años por escrito</strong> en equipo y mano
de obra, mantenimiento preventivo programado y monitoreo 24/7 opcional — sin contratos forzosos
ni mensualidad obligatoria. Pagas tu sistema una vez y es tuyo para siempre.`,
    },
  ],
  col2HighlightStat,
  col2Features = [],
  col2TrustStrip = [],

  quickLinks: quickLinksProp,
  showRecBadge = true,
  showQuickLinks = true,
} = Astro.props;

const icons: Record<string, string> = {
  home: '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  store: '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/><path d="M9 13a3 3 0 1 0 6 0"/>',
  factory: '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/><path d="M7 17h2M11 17h2M15 17h2"/>',
  eye: '<path d="M2 12s4-8 10-8 10 8 10 8-4 8-10 8S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/>',
  wrench: '<path d="M14.7 6.3a4 4 0 1 1 3 3L8 19a2.8 2.8 0 0 1-4-4l10.7-8.7Z"/>',
  camera: '<path d="M3 8a2 2 0 0 1 2-2h3l2-2h4l2 2h3a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z"/><circle cx="12" cy="13" r="4"/>',
  lock: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>',
  bell: '<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>',
  monitor: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>',
  car: '<path d="M5 13l2-5h10l2 5"/><path d="M5 13v5h2v-2h10v2h2v-5z"/><circle cx="8" cy="16" r="1.5"/><circle cx="16" cy="16" r="1.5"/>',
  thermal: '<path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4 4 0 1 0 5 0Z"/>',
  ptz: '<circle cx="12" cy="12" r="9"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>',
  lpr: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 2v5M8 2v5M2 12h20"/>',
  fingerprint: '<path d="M2 12C2 6.5 6.5 2 12 2a10 10 0 0 1 8 4"/><path d="M5 19.5C5.5 18 6 15 6 12c0-3.3 2.7-6 6-6 1.8 0 3.4.8 4.5 2"/>',
  map: '<path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>',
  clock: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  help: '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>',
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/>',
  about: '<circle cx="12" cy="7" r="4"/><path d="M5.5 21a6.5 6.5 0 0 1 13 0"/>',
};

const defaultQuickLinks = [
  { href: '/servicios/camaras-para-hogar/',         title: 'Hogar',        sub: 'Casas · Departamentos · Cocheras', icon: 'home'    },
  { href: '/servicios/camaras-para-comercio/',      title: 'Comercio',     sub: 'Tiendas · Oficinas · Bodegas',     icon: 'store'   },
  { href: '/servicios/sistemas-cctv-industriales/', title: 'Industrial',   sub: 'Fábricas · Naves · Patios',        icon: 'factory' },
  { href: '/servicios/control-de-acceso/',          title: 'Control acceso', sub: 'Videoporteros · Biométricos · LPR', icon: 'lock'  },
  { href: '/contacto/',                             title: 'Cotización',   sub: 'Respuesta WhatsApp < 15 min',      icon: 'phone'   },
];

const quickLinks = quickLinksProp ?? defaultQuickLinks;
---

<section
  class="relative overflow-hidden bg-cream-100"
  aria-labelledby="hero-title"
>
  {
    showRecBadge && (
      <div class="absolute right-4 top-4 z-20 lg:right-8 lg:top-8">
        <span class="rec-badge">REC · Sistema activo</span>
      </div>
    )
  }

  <!-- Línea vertical decorativa al centro entre columnas -->
  <div
    class="absolute left-1/2 top-0 -z-0 hidden h-full w-px bg-cream-300 lg:block"
    aria-hidden="true"
  ></div>

  <div class="container relative py-16 sm:py-20 lg:py-28">
    <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- COLUMNA 1 -->
      <div class="animate-fade-up">
        <span class="eyebrow">{eyebrow}</span>

        <p
          class="mt-7 font-display text-base font-bold uppercase tracking-[0.18em] text-ink-600"
        >
          {preTitle}
        </p>

        <h1 id="hero-title" class="heading-xl mt-3 text-balance">
          {title1}
          <br /><span class="text-accent-500">{title2}</span>
        </h1>

        <p
          class="mt-4 font-display text-xl font-bold leading-tight text-brand-500 sm:text-2xl lg:text-3xl"
        >
          {subtitle}
        </p>

        <span class="marker-line mt-8"></span>

        <p
          class="mt-6 text-[16px] leading-relaxed text-ink-700"
          set:html={descriptionHtml}
        />
      </div>

      <!-- COLUMNA 2 — diseño profesional con stat + paragraphs + features + trust -->
      <div class="animate-fade-up lg:[animation-delay:120ms] lg:pt-2">
        <span class="eyebrow">{col2Eyebrow}</span>

        <h2 class="mt-6 font-display text-2xl font-black leading-tight text-brand-500 sm:text-3xl">
          {col2Title}<span class="text-accent-500">{col2TitleHighlight}</span>.
        </h2>

        <span class="marker-line mt-6"></span>

        <!-- Stat highlight (opcional) -->
        {col2HighlightStat && (
          <div class="mt-6 relative overflow-hidden rounded-2xl border border-brand-500/15 bg-gradient-to-br from-brand-500/[0.06] to-accent-500/[0.04] p-5">
            <div class="absolute -right-4 -top-4 h-20 w-20 rounded-full bg-accent-500/8" aria-hidden="true"></div>
            <div class="relative flex items-center gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-brand-500 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
                  <path d="m9 12 2 2 4-4"/>
                </svg>
              </div>
              <div>
                <p class="font-display text-2xl font-black leading-none text-brand-500">{col2HighlightStat.value}</p>
                <p class="mt-1 text-[12px] font-semibold uppercase tracking-wider text-ink-600">{col2HighlightStat.label}</p>
              </div>
            </div>
          </div>
        )}

        <!-- Párrafos profesionales -->
        <div class="mt-6 space-y-5 text-[16px] leading-[1.75] text-ink-700">
          {col2Paragraphs.map((p) => <p set:html={p.html} />)}
        </div>

        <!-- Features list con checkmarks (opcional) -->
        {col2Features.length > 0 && (
          <ul class="mt-7 grid gap-3 sm:grid-cols-2">
            {col2Features.map((f) => (
              <li class="flex items-start gap-2.5">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-accent-500/10 ring-1 ring-accent-500/20">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 text-accent-500" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                </span>
                <span class="text-[14px] font-semibold leading-snug text-ink-700">{f.text}</span>
              </li>
            ))}
          </ul>
        )}

        <!-- Trust strip — micro badges (opcional) -->
        {col2TrustStrip.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2 border-t border-cream-300 pt-5">
            {col2TrustStrip.map((b) => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-cream-300 bg-white px-3 py-1.5 text-[11.5px] font-bold uppercase tracking-wide text-brand-500 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 text-accent-500" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                {b}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  {
    showQuickLinks && (
      <div class="relative z-10 bg-brand-600">
        <div class="container grid grid-cols-2 divide-y divide-brand-500 sm:grid-cols-3 sm:divide-x sm:divide-y-0 lg:grid-cols-5">
          {quickLinks.map((s) => (
            <a
              href={s.href}
              class="group flex items-center justify-between gap-3 px-4 py-5 transition-colors hover:bg-brand-500"
            >
              <div class="flex items-center gap-3">
                <span class="grid h-10 w-10 place-items-center rounded-md bg-accent-500 text-white">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-5 w-5"
                    aria-hidden="true"
                    set:html={icons[s.icon]}
                  />
                </span>
                <div>
                  <p class="text-sm font-black text-white">{s.title}</p>
                  <p class="text-[11px] text-white/70">{s.sub}</p>
                </div>
              </div>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4 text-white/40 transition-transform group-hover:translate-x-1 group-hover:text-accent-500"
                aria-hidden="true"
              >
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    )
  }
</section>
