---
import { SITE } from '@/consts';

/**
 * Componente SEO maestro.
 * Inyecta meta tags + Open Graph + Twitter + JSON-LD enriquecido.
 *
 * Schemas incluidos por default en TODAS las páginas:
 * - LocalBusiness (con aggregateRating, openingHoursSpecification, areaServed)
 * - WebSite (con SearchAction estructurada)
 * - Organization (referenciada desde LocalBusiness)
 *
 * Schemas opcionales (pasarlos via props):
 * - faq:        FAQPage      → para páginas con FAQs
 * - services:   Service[]    → para páginas de servicios
 * - reviews:    Review[]     → para testimonios
 * - breadcrumb: BreadcrumbList → para subpáginas con jerarquía
 * - article:    Article      → para blog posts
 */

interface FaqEntry {
  q: string;
  a: string;
}

interface ServiceEntry {
  name: string;
  description: string;
  url?: string;
}

interface ReviewEntry {
  author: string;
  rating: number;
  body: string;
  datePublished?: string;
}

interface BreadcrumbEntry {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  // Schemas extra
  faq?: FaqEntry[];
  services?: ServiceEntry[];
  reviews?: ReviewEntry[];
  breadcrumb?: BreadcrumbEntry[];
  // Article (blog)
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description = SITE.defaultDescription,
  image = SITE.defaultImage,
  canonical,
  noindex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  faq,
  services,
  reviews,
  breadcrumb,
  articleAuthor,
  articleSection,
  articleTags,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE.name}` : SITE.defaultTitle;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site ?? SITE.url).toString();
const imageURL = new URL(image, Astro.site ?? SITE.url).toString();

// ───────────────────────────────────────────────────────────
// 1) LOCAL BUSINESS — el "negocio" central, fuente principal
// ───────────────────────────────────────────────────────────
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}/#business`,
  name: SITE.business.legalName,
  alternateName: SITE.name,
  url: SITE.url,
  image: imageURL,
  logo: `${SITE.url}/favicon.svg`,
  description: SITE.defaultDescription,
  telephone: SITE.contact.phone,
  email: SITE.contact.email,
  priceRange: '$$',
  foundingDate: String(SITE.business.foundingYear),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ciudad de México',
    addressRegion: 'CDMX',
    addressCountry: 'MX',
  },
  areaServed: SITE.business.serviceArea.map((area) => ({
    '@type': 'City',
    name: area,
  })),
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 19.4326,
    longitude: -99.1332,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '09:00',
      closes: '19:00',
    },
  ],
  paymentAccepted: 'Efectivo, Transferencia, Tarjeta de crédito, Tarjeta de débito',
  currenciesAccepted: 'MXN',
  knowsAbout: [
    'Cámaras de seguridad CCTV',
    'Sistemas de videovigilancia',
    'Instalación de cámaras IP',
    'Monitoreo 24/7',
    'Control de acceso',
    'Hikvision',
    'Dahua',
    'Provision-ISR',
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '32',
    bestRating: '5',
    worstRating: '1',
  },
  sameAs: [SITE.social.facebook, SITE.social.instagram, SITE.social.youtube],
};

// ───────────────────────────────────────────────────────────
// 2) WEBSITE — con SearchAction opcional
// ───────────────────────────────────────────────────────────
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.defaultDescription,
  inLanguage: SITE.locale,
  publisher: { '@id': `${SITE.url}/#business` },
};

// ───────────────────────────────────────────────────────────
// 3) WEBPAGE actual
// ───────────────────────────────────────────────────────────
const webpage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalURL}#webpage`,
  url: canonicalURL,
  name: pageTitle,
  description,
  isPartOf: { '@id': `${SITE.url}/#website` },
  about: { '@id': `${SITE.url}/#business` },
  inLanguage: SITE.locale,
  ...(publishedTime && { datePublished: publishedTime }),
  ...(modifiedTime && { dateModified: modifiedTime }),
  primaryImageOfPage: { '@type': 'ImageObject', url: imageURL },
};

// ───────────────────────────────────────────────────────────
// 4) Schemas dinámicos según props
// ───────────────────────────────────────────────────────────
const extraSchemas: Record<string, unknown>[] = [];

if (breadcrumb && breadcrumb.length > 0) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumb.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: new URL(b.url, SITE.url).toString(),
    })),
  });
}

if (faq && faq.length > 0) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

if (services && services.length > 0) {
  services.forEach((svc) => {
    extraSchemas.push({
      '@context': 'https://schema.org',
      '@type': 'Service',
      name: svc.name,
      description: svc.description,
      ...(svc.url && { url: new URL(svc.url, SITE.url).toString() }),
      provider: { '@id': `${SITE.url}/#business` },
      areaServed: SITE.business.serviceArea.map((a) => ({ '@type': 'City', name: a })),
      serviceType: 'Cámaras de seguridad CCTV',
    });
  });
}

if (reviews && reviews.length > 0) {
  reviews.forEach((r) => {
    extraSchemas.push({
      '@context': 'https://schema.org',
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE.url}/#business` },
      author: { '@type': 'Person', name: r.author },
      reviewRating: { '@type': 'Rating', ratingValue: String(r.rating), bestRating: '5' },
      reviewBody: r.body,
      ...(r.datePublished && { datePublished: r.datePublished }),
    });
  });
}

// Article schema (blog posts)
if (type === 'article' && publishedTime) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    image: imageURL,
    datePublished: publishedTime,
    ...(modifiedTime && { dateModified: modifiedTime }),
    author: {
      '@type': articleAuthor === SITE.business.legalName ? 'Organization' : 'Person',
      name: articleAuthor ?? SITE.business.legalName,
    },
    publisher: { '@id': `${SITE.url}/#business` },
    mainEntityOfPage: { '@id': `${canonicalURL}#webpage` },
    ...(articleSection && { articleSection }),
    ...(articleTags && { keywords: articleTags.join(', ') }),
  });
}
---

<!-- ════════════════════════════════════════════════════════ -->
<!-- META BÁSICOS                                              -->
<!-- ════════════════════════════════════════════════════════ -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
<meta name="author" content={SITE.business.legalName} />
<meta name="publisher" content={SITE.business.legalName} />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
{!noindex && <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1" />}

<!-- Geo & lang -->
<meta name="geo.region" content="MX-CMX" />
<meta name="geo.placename" content="Ciudad de México" />
<meta name="geo.position" content="19.4326;-99.1332" />
<meta name="ICBM" content="19.4326, -99.1332" />
<meta name="language" content="Spanish" />
<link rel="alternate" hreflang="es-mx" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- Theme / color -->
<meta name="theme-color" content={SITE.themeColor} />
<meta name="msapplication-TileColor" content={SITE.themeColor} />
<meta name="color-scheme" content="light" />
<meta name="format-detection" content="telephone=no" />

<!-- ════════════════════════════════════════════════════════ -->
<!-- OPEN GRAPH / FACEBOOK                                     -->
<!-- ════════════════════════════════════════════════════════ -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:secure_url" content={imageURL} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={pageTitle} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{articleAuthor && <meta property="article:author" content={articleAuthor} />}
{articleSection && <meta property="article:section" content={articleSection} />}
{articleTags && articleTags.map((t) => <meta property="article:tag" content={t} />)}

<!-- ════════════════════════════════════════════════════════ -->
<!-- TWITTER                                                   -->
<!-- ════════════════════════════════════════════════════════ -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={pageTitle} />

<!-- ════════════════════════════════════════════════════════ -->
<!-- ICONS                                                     -->
<!-- ════════════════════════════════════════════════════════ -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/favicon.svg" />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Preconnect a Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Open+Sans:wght@400;500;600;700&display=swap"
/>

<!-- ════════════════════════════════════════════════════════ -->
<!-- JSON-LD STRUCTURED DATA                                   -->
<!-- ════════════════════════════════════════════════════════ -->
<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
<script type="application/ld+json" set:html={JSON.stringify(website)} />
<script type="application/ld+json" set:html={JSON.stringify(webpage)} />
{extraSchemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
