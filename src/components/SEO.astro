---
import { SITE } from '@/consts';

/**
 * Componente SEO maestro.
 * Inyecta meta tags + Open Graph + Twitter + JSON-LD enriquecido.
 *
 * Schemas SIEMPRE incluidos:
 * - Organization
 * - LocalBusiness (con aggregateRating, openingHoursSpecification, areaServed)
 * - WebSite (con SearchAction estructurada)
 * - WebPage
 *
 * Schemas opcionales (pasarlos via props):
 * - faq          → FAQPage
 * - services     → Service[]   (con aggregateRating heredado)
 * - reviews      → Review[]
 * - breadcrumb   → BreadcrumbList
 * - article      → Article
 * - howTo        → HowTo
 * - contactPoint → ContactPoint[]
 * - places       → Place[]
 * - products     → Product[]
 */

interface FaqEntry {
  q: string;
  a: string;
}

interface ServiceEntry {
  name: string;
  description: string;
  url?: string;
  serviceType?: string;
}

interface ReviewEntry {
  author: string;
  rating: number;
  body: string;
  datePublished?: string;
}

interface BreadcrumbEntry {
  name: string;
  url: string;
}

interface HowToStepEntry {
  name: string;
  text: string;
  url?: string;
}

interface HowToEntry {
  name: string;
  description: string;
  totalTime?: string; // ISO 8601 duration, ej "PT1D"
  steps: HowToStepEntry[];
}

interface ContactPointEntry {
  contactType: string; // "customer service", "sales", "emergency"
  telephone?: string;
  email?: string;
  areaServed?: string | string[];
  availableLanguage?: string | string[];
  hoursAvailable?: string;
}

interface PlaceEntry {
  name: string;
  type?: 'AdministrativeArea' | 'City' | 'State' | 'Country';
  containedInPlace?: string;
}

interface ProductEntry {
  name: string;
  description: string;
  price?: number;
  priceCurrency?: string;
  brand?: string;
  category?: string;
  sku?: string;
  url?: string;
  image?: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string;
  // Schemas extra
  faq?: FaqEntry[];
  services?: ServiceEntry[];
  reviews?: ReviewEntry[];
  breadcrumb?: BreadcrumbEntry[];
  howTo?: HowToEntry;
  contactPoints?: ContactPointEntry[];
  places?: PlaceEntry[];
  products?: ProductEntry[];
  // Article (blog)
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description = SITE.defaultDescription,
  image = SITE.defaultImage,
  canonical,
  noindex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  keywords,
  faq,
  services,
  reviews,
  breadcrumb,
  howTo,
  contactPoints,
  places,
  products,
  articleAuthor,
  articleSection,
  articleTags,
} = Astro.props;

// Si el title ya contiene el brand o supera 60 chars, no se duplica.
const hasBrand = title?.toLowerCase().includes(SITE.name.toLowerCase());
const pageTitle = title
  ? (hasBrand || title.length > 60 ? title : `${title} | ${SITE.name}`)
  : SITE.defaultTitle;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site ?? SITE.url).toString();
const imageURL = new URL(image, Astro.site ?? SITE.url).toString();

const phoneE164 = SITE.contact.phone.replace(/[^+0-9]/g, '');

// ───────────────────────────────────────────────────────────
// 1) ORGANIZATION — entidad legal independiente
// ───────────────────────────────────────────────────────────
const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.business.legalName,
  alternateName: SITE.shortName,
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/favicon.svg`,
    width: '512',
    height: '512',
  },
  image: imageURL,
  description: SITE.defaultDescription,
  slogan: 'Seguridad real, instalación profesional, garantía por escrito',
  foundingDate: String(SITE.business.foundingYear),
  knowsLanguage: ['es-MX', 'es'],
  knowsAbout: [
    'Cámaras de seguridad CCTV',
    'Videovigilancia profesional',
    'Sistemas de monitoreo 24/7',
    'Cámaras IP 4K',
    'Cámaras PTZ',
    'Cámaras térmicas',
    'Control de acceso biométrico',
    'Lectura de placas vehiculares LPR',
    'Instalación de cámaras Hikvision',
    'Instalación de cámaras Dahua',
    'Instalación de cámaras Provision-ISR',
  ],
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      telephone: SITE.contact.phone,
      email: SITE.contact.email,
      areaServed: 'MX',
      availableLanguage: ['Spanish', 'es-MX'],
    },
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      telephone: SITE.contact.phone,
      areaServed: ['MX-CMX', 'MX-MEX', 'MX-JAL', 'MX-NLE'],
      availableLanguage: 'Spanish',
    },
  ],
  sameAs: [SITE.social.facebook, SITE.social.instagram, SITE.social.youtube].filter(Boolean),
};

// ───────────────────────────────────────────────────────────
// 2) LOCAL BUSINESS — operación local con servicios ofrecidos
// ───────────────────────────────────────────────────────────
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'SecuritySystemInstallationService'],
  '@id': `${SITE.url}/#business`,
  name: SITE.business.legalName,
  alternateName: SITE.name,
  url: SITE.url,
  image: imageURL,
  logo: `${SITE.url}/favicon.svg`,
  description: SITE.defaultDescription,
  slogan: 'Seguridad real, sin promesas vacías',
  telephone: SITE.contact.phone,
  email: SITE.contact.email,
  priceRange: '$$',
  foundingDate: String(SITE.business.foundingYear),
  parentOrganization: { '@id': `${SITE.url}/#organization` },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ciudad de México',
    addressRegion: 'CDMX',
    addressCountry: 'MX',
  },
  areaServed: SITE.business.serviceArea.map((area) => ({
    '@type': 'City',
    name: area,
  })),
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 19.4326,
    longitude: -99.1332,
  },
  hasMap: 'https://www.google.com/maps/place/Ciudad+de+M%C3%A9xico',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '09:00',
      closes: '15:00',
    },
  ],
  paymentAccepted: 'Efectivo, Transferencia, Tarjeta de crédito, Tarjeta de débito',
  currenciesAccepted: 'MXN',
  knowsLanguage: ['es-MX', 'es'],
  knowsAbout: [
    'Cámaras de seguridad CCTV',
    'Sistemas de videovigilancia',
    'Instalación de cámaras IP',
    'Monitoreo 24/7',
    'Control de acceso',
    'Hikvision',
    'Dahua',
    'Provision-ISR',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de instalación CCTV',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Cámaras de seguridad para hogar', url: `${SITE.url}/servicios/hogar/` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Cámaras de seguridad para comercio', url: `${SITE.url}/servicios/comercio/` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Sistemas CCTV industriales', url: `${SITE.url}/servicios/industrial/` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Control de acceso', url: `${SITE.url}/servicios/control-acceso/` } },
    ],
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '230',
    bestRating: '5',
    worstRating: '1',
  },
  sameAs: [SITE.social.facebook, SITE.social.instagram, SITE.social.youtube].filter(Boolean),
};

// ───────────────────────────────────────────────────────────
// 3) WEBSITE — con SearchAction
// ───────────────────────────────────────────────────────────
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.defaultDescription,
  inLanguage: SITE.locale,
  publisher: { '@id': `${SITE.url}/#organization` },
};

// ───────────────────────────────────────────────────────────
// 4) WEBPAGE actual
// ───────────────────────────────────────────────────────────
const webpage: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalURL}#webpage`,
  url: canonicalURL,
  name: pageTitle,
  description,
  isPartOf: { '@id': `${SITE.url}/#website` },
  about: { '@id': `${SITE.url}/#business` },
  inLanguage: SITE.locale,
  ...(publishedTime && { datePublished: publishedTime }),
  ...(modifiedTime && { dateModified: modifiedTime }),
  primaryImageOfPage: { '@type': 'ImageObject', url: imageURL },
};

if (breadcrumb && breadcrumb.length > 0) {
  webpage.breadcrumb = { '@id': `${canonicalURL}#breadcrumb` };
}

// ───────────────────────────────────────────────────────────
// 5) Schemas dinámicos según props
// ───────────────────────────────────────────────────────────
const extraSchemas: Record<string, unknown>[] = [];

if (breadcrumb && breadcrumb.length > 0) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    '@id': `${canonicalURL}#breadcrumb`,
    itemListElement: breadcrumb.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: new URL(b.url, SITE.url).toString(),
    })),
  });
}

if (faq && faq.length > 0) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': `${canonicalURL}#faq`,
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

if (services && services.length > 0) {
  services.forEach((svc, idx) => {
    extraSchemas.push({
      '@context': 'https://schema.org',
      '@type': 'Service',
      '@id': svc.url ? `${new URL(svc.url, SITE.url).toString()}#service` : `${canonicalURL}#service-${idx}`,
      name: svc.name,
      description: svc.description,
      ...(svc.url && { url: new URL(svc.url, SITE.url).toString() }),
      provider: { '@id': `${SITE.url}/#business` },
      areaServed: SITE.business.serviceArea.map((a) => ({ '@type': 'City', name: a })),
      serviceType: svc.serviceType ?? 'Instalación de cámaras de seguridad CCTV',
      audience: { '@type': 'Audience', audienceType: 'Residential, Commercial, Industrial' },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.9',
        reviewCount: '230',
        bestRating: '5',
        worstRating: '1',
      },
    });
  });
}

if (reviews && reviews.length > 0) {
  reviews.forEach((r) => {
    extraSchemas.push({
      '@context': 'https://schema.org',
      '@type': 'Review',
      itemReviewed: { '@id': `${SITE.url}/#business` },
      author: { '@type': 'Person', name: r.author },
      reviewRating: { '@type': 'Rating', ratingValue: String(r.rating), bestRating: '5' },
      reviewBody: r.body,
      ...(r.datePublished && { datePublished: r.datePublished }),
    });
  });
}

// HowTo (paso a paso, ideal para /proceso/)
if (howTo && howTo.steps.length > 0) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    '@id': `${canonicalURL}#howto`,
    name: howTo.name,
    description: howTo.description,
    image: imageURL,
    ...(howTo.totalTime && { totalTime: howTo.totalTime }),
    step: howTo.steps.map((step, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: step.name,
      text: step.text,
      ...(step.url && { url: new URL(step.url, SITE.url).toString() }),
    })),
  });
}

// ContactPoints adicionales (para /contacto/)
if (contactPoints && contactPoints.length > 0) {
  contactPoints.forEach((cp, i) => {
    extraSchemas.push({
      '@context': 'https://schema.org',
      '@type': 'ContactPoint',
      '@id': `${canonicalURL}#contact-${i}`,
      contactType: cp.contactType,
      ...(cp.telephone && { telephone: cp.telephone }),
      ...(cp.email && { email: cp.email }),
      ...(cp.areaServed && { areaServed: cp.areaServed }),
      ...(cp.availableLanguage && { availableLanguage: cp.availableLanguage }),
      ...(cp.hoursAvailable && { hoursAvailable: cp.hoursAvailable }),
    });
  });
}

// Places servidos (para /cobertura/)
if (places && places.length > 0) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    '@id': `${canonicalURL}#places`,
    name: 'Zonas de cobertura',
    itemListElement: places.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': p.type ?? 'AdministrativeArea',
        name: p.name,
        ...(p.containedInPlace && {
          containedInPlace: { '@type': 'AdministrativeArea', name: p.containedInPlace },
        }),
      },
    })),
  });
}

// Products (paquetes con precio)
if (products && products.length > 0) {
  products.forEach((p, i) => {
    extraSchemas.push({
      '@context': 'https://schema.org',
      '@type': 'Product',
      '@id': `${canonicalURL}#product-${i}`,
      name: p.name,
      description: p.description,
      ...(p.image && { image: new URL(p.image, SITE.url).toString() }),
      ...(p.sku && { sku: p.sku }),
      ...(p.category && { category: p.category }),
      brand: {
        '@type': 'Brand',
        name: p.brand ?? SITE.business.legalName,
      },
      ...(p.price !== undefined && {
        offers: {
          '@type': 'Offer',
          price: String(p.price),
          priceCurrency: p.priceCurrency ?? 'MXN',
          availability: 'https://schema.org/InStock',
          priceValidUntil: `${new Date().getFullYear() + 1}-12-31`,
          seller: { '@id': `${SITE.url}/#business` },
          ...(p.url && { url: new URL(p.url, SITE.url).toString() }),
        },
      }),
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.9',
        reviewCount: '230',
        bestRating: '5',
        worstRating: '1',
      },
    });
  });
}

// Article schema (blog posts)
if (type === 'article' && publishedTime) {
  extraSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    image: imageURL,
    datePublished: publishedTime,
    ...(modifiedTime && { dateModified: modifiedTime }),
    author: {
      '@type': articleAuthor === SITE.business.legalName ? 'Organization' : 'Person',
      name: articleAuthor ?? SITE.business.legalName,
    },
    publisher: { '@id': `${SITE.url}/#organization` },
    mainEntityOfPage: { '@id': `${canonicalURL}#webpage` },
    ...(articleSection && { articleSection }),
    ...(articleTags && { keywords: articleTags.join(', ') }),
  });
}
---

<!-- ════════════════════════════════════════════════════════ -->
<!-- META BÁSICOS                                              -->
<!-- ════════════════════════════════════════════════════════ -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="author" content={SITE.business.legalName} />
<meta name="publisher" content={SITE.business.legalName} />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
{!noindex && <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1" />}
{!noindex && <meta name="bingbot" content="index, follow" />}

<!-- Geo & lang -->
<meta name="geo.region" content="MX-CMX" />
<meta name="geo.placename" content="Ciudad de México" />
<meta name="geo.position" content="19.4326;-99.1332" />
<meta name="ICBM" content="19.4326, -99.1332" />
<meta name="language" content="Spanish" />
<meta http-equiv="content-language" content="es-MX" />
<link rel="alternate" hreflang="es-mx" href={canonicalURL} />
<link rel="alternate" hreflang="es" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- Theme / color -->
<meta name="theme-color" content={SITE.themeColor} />
<meta name="msapplication-TileColor" content={SITE.themeColor} />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="color-scheme" content="light" />
<meta name="format-detection" content="telephone=no" />
<meta name="referrer" content="strict-origin-when-cross-origin" />

<!-- ════════════════════════════════════════════════════════ -->
<!-- OPEN GRAPH / FACEBOOK                                     -->
<!-- ════════════════════════════════════════════════════════ -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:locale:alternate" content="es_MX" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:secure_url" content={imageURL} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={pageTitle} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{articleAuthor && <meta property="article:author" content={articleAuthor} />}
{articleSection && <meta property="article:section" content={articleSection} />}
{articleTags && articleTags.map((t) => <meta property="article:tag" content={t} />)}

<!-- ════════════════════════════════════════════════════════ -->
<!-- TWITTER                                                   -->
<!-- ════════════════════════════════════════════════════════ -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={pageTitle} />

<!-- ════════════════════════════════════════════════════════ -->
<!-- ICONS                                                     -->
<!-- ════════════════════════════════════════════════════════ -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/favicon.svg" />
<link rel="manifest" href="/manifest.webmanifest" />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- ════════════════════════════════════════════════════════ -->
<!-- PERFORMANCE: preconnect, dns-prefetch, preload OG          -->
<!-- ════════════════════════════════════════════════════════ -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://wa.me" />
<link rel="preload" as="image" href={imageURL} />
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Open+Sans:wght@400;500;600;700&display=swap"
/>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Open+Sans:wght@400;500;600;700&display=swap"
  media="all"
/>

<!-- ════════════════════════════════════════════════════════ -->
<!-- JSON-LD STRUCTURED DATA                                   -->
<!-- ════════════════════════════════════════════════════════ -->
<script type="application/ld+json" set:html={JSON.stringify(organization)} />
<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
<script type="application/ld+json" set:html={JSON.stringify(website)} />
<script type="application/ld+json" set:html={JSON.stringify(webpage)} />
{extraSchemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
