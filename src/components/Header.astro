---
import { SERVICE_LINKS, SITE } from '@/consts';
import TopBar from '@components/TopBar.astro';

const path = Astro.url.pathname;
const segments = path.split('/').filter(Boolean);
const isHome = segments.length === 0;

const segmentLabel = (slug: string): string => {
  const labels: Record<string, string> = {
    nosotros: 'Nosotros',
    proceso: 'Cómo trabajamos',
    cobertura: 'Cobertura',
    faq: 'Preguntas frecuentes',
    servicios: 'Servicios',
    hogar: 'Hogar',
    comercio: 'Comercio',
    industrial: 'Industrial',
    'control-acceso': 'Control de Acceso',
    blog: 'Blog',
    productos: 'Productos',
    contacto: 'Contacto',
    'aviso-de-privacidad': 'Aviso de privacidad',
    terminos: 'Términos',
  };
  return labels[slug] ?? slug.charAt(0).toUpperCase() + slug.slice(1).replace(/-/g, ' ');
};

const breadcrumb = isHome
  ? [{ label: 'Inicio', href: '/' }]
  : [
      { label: 'Inicio', href: '/' },
      ...segments.map((seg, i) => ({
        label: segmentLabel(seg),
        href: '/' + segments.slice(0, i + 1).join('/') + '/',
      })),
    ];

// Iconos SVG para el mega-menu de servicios
const serviceIcons: Record<string, string> = {
  '/servicios/camaras-para-hogar/':          '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  '/servicios/camaras-para-comercio/':       '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/>',
  '/servicios/sistemas-cctv-industriales/':     '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/>',
  '/servicios/control-de-acceso/': '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
};

const serviceDescriptions: Record<string, string> = {
  '/servicios/camaras-para-hogar/':          'Protege tu familia y patrimonio',
  '/servicios/camaras-para-comercio/':       'Tiendas, oficinas y negocios',
  '/servicios/sistemas-cctv-industriales/':     'Plantas, naves y bodegas',
  '/servicios/control-de-acceso/': 'Videoporteros y cerraduras IP',
};

// Iconos para links directos en móvil
const mobileNavIcons: Record<string, string> = {
  '/sobre-nosotros/':  '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>',
  '/como-trabajamos/':   '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  '/cobertura-cdmx-edomex/': '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/>',
  '/preguntas-frecuentes/':       '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/>',
  '/contacto/':  '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.92 3.42 2 2 0 0 1 3.9 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/>',
};

// Links directos en el nav principal
const mainNavLinks = [
  { href: '/sobre-nosotros/',  label: 'Nosotros' },
  { href: '/como-trabajamos/',   label: 'Proceso' },
  { href: '/cobertura-cdmx-edomex/', label: 'Cobertura' },
  { href: '/preguntas-frecuentes/',       label: 'FAQ' },
  { href: '/contacto/',  label: 'Contacto' },
];
---

<TopBar />

<header
  id="site-header"
  class="sticky top-0 z-40 w-full border-b border-cream-300 bg-white/95 backdrop-blur-sm transition-shadow duration-200"
>
  <div class="container flex h-[68px] items-center justify-between gap-4 lg:h-20">

    <!-- ── LOGO ──────────────────────────────────────────────── -->
    <a
      href="/"
      class="group flex shrink-0 flex-col leading-none transition-opacity hover:opacity-85"
      aria-label={`${SITE.name} — Inicio`}
    >
      <span class="font-display text-[22px] font-black tracking-tight text-brand-500 transition-colors group-hover:text-brand-600 lg:text-[25px]">
        CÁMARA<span class="text-accent-500">.</span>SEGURIDAD
      </span>
      <span class="mt-[3px] text-[9.5px] font-bold uppercase tracking-[0.3em] text-ink-400 lg:text-[10px]">
        CCTV · INSTALACIÓN · MONITOREO
      </span>
    </a>

    <!-- ── NAV DESKTOP ───────────────────────────────────────── -->
    <nav class="hidden items-center gap-0 lg:flex" aria-label="Navegación principal">

      <!-- Inicio -->
      <a href="/" class="nav-link" aria-current={isHome ? 'page' : undefined}>Inicio</a>

      <!-- Servicios — mega-dropdown -->
      <div class="group relative">
        <a
          href="/servicios/"
          class="nav-link flex items-center gap-1.5"
          aria-haspopup="true"
        >
          Servicios
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </a>

        <!-- Dropdown panel -->
        <div class="dropdown-panel w-[260px]">
          <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.22em] text-ink-400">Tipo de instalación</p>
          <div>
            {SERVICE_LINKS.map((link) => (
              <a href={link.href} class="dropdown-item group/item">
                <span class="min-w-0 flex-1">
                  <span class="block text-[14px] font-semibold text-ink-800 transition-colors group-hover/item:text-accent-500">{link.label}</span>
                  <span class="block text-[12px] text-ink-400">{serviceDescriptions[link.href]}</span>
                </span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 shrink-0 text-ink-200 transition-all group-hover/item:translate-x-0.5 group-hover/item:text-accent-500" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            ))}
          </div>
          <div class="mt-2 border-t border-cream-200 pt-2">
            <a href="/servicios/" class="flex items-center justify-between rounded-lg bg-brand-500 px-3 py-2.5 text-[13px] font-bold text-white transition-colors hover:bg-brand-600">
              <span>Ver todos los servicios</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Links directos del nav -->
      {mainNavLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <!-- ── CTA + Hamburger ───────────────────────────────────── -->
    <div class="flex items-center gap-2 lg:gap-3">
      <!-- CTA escritorio -->
      <a
        href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent('Hola, me interesa información sobre cámaras de seguridad.')}`}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-2 lg:inline-flex btn-primary"
      >
        <!-- WhatsApp icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Cotiza Gratis
      </a>

      <!-- CTA móvil compacto -->
      <a
        href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent('Hola, quiero una cotización gratuita.')}`}
        target="_blank"
        rel="noopener"
        class="grid h-10 w-10 place-items-center rounded-md bg-accent-500 text-white transition-colors hover:bg-accent-600 lg:hidden"
        aria-label="Cotizar por WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
      </a>

      <!-- Hamburger -->
      <button
        id="mobile-menu-toggle"
        class="grid h-10 w-10 place-items-center rounded-md text-brand-500 transition-colors hover:bg-cream-100 lg:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden h-6 w-6" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- ── MOBILE MENU ─────────────────────────────────────────── -->
  <div
    id="mobile-menu"
    class="hidden border-t-2 border-accent-500 bg-white lg:hidden"
    aria-hidden="true"
  >
    <nav class="container py-4" aria-label="Navegación móvil">

      <!-- Inicio -->
      <a href="/" class="mobile-link">Inicio</a>

      <!-- Servicios acordeón -->
      <div class="border-t border-cream-100">
        <div class="flex items-center">
          <a href="/servicios/" class="mobile-link flex-1">Servicios</a>
          <button id="mobile-servicios-toggle" class="grid h-10 w-10 shrink-0 place-items-center rounded-md text-ink-400 transition-colors hover:text-accent-500" aria-expanded="false" aria-label="Ver sub-servicios">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transition-transform duration-200" id="servicios-chevron" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
        </div>

        <div id="mobile-servicios-panel" class="hidden pb-2">
          <!-- Sub-links servicios -->
          {SERVICE_LINKS.map((link) => (
            <a href={link.href} class="mobile-sublink group/sub">
              <span class="flex-1">
                <span class="block text-[14.5px] font-semibold text-ink-700 transition-colors group-hover/sub:text-accent-500">{link.label}</span>
                <span class="block text-[12px] text-ink-400">{serviceDescriptions[link.href]}</span>
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 shrink-0 text-ink-200 transition-colors group-hover/sub:text-accent-500" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          ))}
          <a href="/servicios/" class="mobile-sublink group/sub font-bold text-brand-500">
            <span class="flex-1 text-[13.5px] transition-colors group-hover/sub:text-accent-500">Ver todos los servicios</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 shrink-0 text-brand-300 transition-colors group-hover/sub:text-accent-500" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Links directos -->
      {mainNavLinks.map((link) => (
        <div class="border-t border-cream-100">
          <a href={link.href} class="mobile-link">{link.label}</a>
        </div>
      ))}

      <!-- CTA -->
      <div class="mt-5 border-t border-cream-100 pt-5">
        <a
          href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent('Hola, quiero una cotización gratuita.')}`}
          target="_blank"
          rel="noopener"
          class="btn-primary w-full text-[15px] py-4"
        >
          Cotiza Gratis por WhatsApp
        </a>
        <p class="mt-2.5 text-center text-[11.5px] text-ink-400">Respondemos en menos de 15 minutos</p>
      </div>
    </nav>
  </div>
</header>

<!-- Breadcrumb -->
<nav class="bg-brand-500 text-cream-50" aria-label="Breadcrumb">
  <div class="container flex h-11 items-center gap-2 text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 shrink-0 text-accent-400" aria-hidden="true">
      <path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-6h-2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/>
    </svg>
    <ol class="flex items-center gap-1.5 overflow-x-auto whitespace-nowrap">
      {breadcrumb.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 text-cream-50/30" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          )}
          {i === breadcrumb.length - 1 ? (
            <span class="text-[13px] font-semibold text-accent-300" aria-current="page">{item.label}</span>
          ) : (
            <a href={item.href} class="text-[13px] text-cream-50/75 transition-colors hover:text-accent-300">{item.label}</a>
          )}
        </li>
      ))}
    </ol>
  </div>
  <div class="h-0.5 w-full bg-brand-600">
    <div class="h-full w-1/5 bg-accent-500 rounded-r-full"></div>
  </div>
</nav>

<style>
  .nav-link {
    @apply rounded-md px-3 py-2 text-[14px] font-semibold text-ink-700 transition-colors hover:bg-cream-100 hover:text-brand-500;
  }

  .nav-link[aria-current="page"] {
    @apply bg-cream-100 text-brand-500;
  }

  .mobile-link {
    @apply flex items-center justify-between px-0 py-4 text-[16px] font-bold text-ink-800 transition-colors hover:text-accent-500;
  }

  .mobile-sublink {
    @apply flex items-center gap-3 border-l-2 border-cream-200 py-2.5 pl-4 pr-1 transition-all hover:border-accent-500;
  }

  /* Dropdown panel */
  .dropdown-panel {
    @apply invisible absolute left-0 top-full z-50 mt-2 origin-top-left scale-95 rounded-2xl border border-cream-200 bg-white p-4 opacity-0 shadow-[0_8px_30px_rgba(0,0,0,0.12)] transition-all duration-150;
  }

  .group:hover .dropdown-panel,
  .group:focus-within .dropdown-panel {
    @apply visible scale-100 opacity-100;
  }

  .dropdown-item {
    @apply flex items-center gap-3 rounded-lg border-l-2 border-transparent px-3 py-2.5 transition-all duration-100 hover:border-accent-500 hover:bg-cream-50;
  }
</style>

<script>
  // ── Shadow on scroll ─────────────────────────────────────────
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => header.classList.toggle('shadow-[0_2px_16px_rgba(10,37,64,0.10)]', window.scrollY > 8);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // ── Mobile menu toggle ───────────────────────────────────────
  const toggle    = document.getElementById('mobile-menu-toggle');
  const menu      = document.getElementById('mobile-menu');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      menu.setAttribute('aria-hidden', String(isOpen));
      toggle.setAttribute('aria-expanded', String(!isOpen));
      iconMenu?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
      document.body.classList.toggle('overflow-hidden', !isOpen);
    });

    // Cierra al hacer click en cualquier link del menú móvil
    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        menu.classList.add('hidden');
        menu.setAttribute('aria-hidden', 'true');
        toggle.setAttribute('aria-expanded', 'false');
        iconMenu?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      });
    });
  }

  // ── Mobile acordeón Servicios ────────────────────────────────
  const servBtn     = document.getElementById('mobile-servicios-toggle');
  const servPanel   = document.getElementById('mobile-servicios-panel');
  const servChevron = document.getElementById('servicios-chevron');

  if (servBtn && servPanel) {
    servBtn.addEventListener('click', () => {
      const open = !servPanel.classList.contains('hidden');
      servPanel.classList.toggle('hidden', open);
      servChevron?.classList.toggle('rotate-180', !open);
      servBtn.setAttribute('aria-expanded', String(!open));
    });
  }

  // ── Escape cierra dropdowns ──────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      (document.activeElement as HTMLElement)?.blur();
    }
  });
</script>
