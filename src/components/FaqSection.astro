---
interface FaqEntry {
  q: string;
  a: string;
}

interface Props {
  faqs?: FaqEntry[];
}

// Fallback de FAQs por default (si no se pasa via props).
// El uso recomendado es pasar el mismo array desde la página
// y reutilizarlo también para el JSON-LD del SEO.
const defaultFaqs: FaqEntry[] = [
  {
    q: '¿Cuánto cuesta instalar cámaras de seguridad en mi casa?',
    a: 'En CDMX y Estado de México, una instalación básica de 2 cámaras HD con todo incluido cuesta desde $3,490 MXN. La cotización por WhatsApp es gratis y te llega el mismo día.',
  },
];

const { faqs = defaultFaqs } = Astro.props;
---

<section class="section-white">
  <div class="container">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.4fr] lg:gap-16">
      <div class="lg:sticky lg:top-32 lg:self-start">
        <span class="eyebrow">Preguntas frecuentes</span>
        <h2 class="heading-lg mt-4 text-balance">
          Lo que la gente nos pregunta
          <span class="text-accent-500">antes de cotizar</span>.
        </h2>
        <span class="marker-line mt-5"></span>
        <p class="lead mt-6">
          Si tu pregunta no está aquí, escríbenos por WhatsApp y te respondemos en menos de
          15 minutos — sin formularios ni vendedores.
        </p>

        <a
          href="#contacto"
          class="btn-primary mt-8 inline-flex"
        >
          Pregúntanos por WhatsApp
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div class="space-y-3">
        {
          faqs.map((f, i) => (
            <details
              class="faq-item group overflow-hidden rounded-xl border border-cream-300 bg-cream-50 transition-colors open:border-brand-500 open:bg-white open:shadow-soft"
              open={i === 0}
            >
              <summary class="flex cursor-pointer items-start justify-between gap-4 px-6 py-5 list-none">
                <h3 class="font-display text-[16.5px] font-black leading-snug text-brand-500 transition-colors group-hover:text-accent-500">
                  {f.q}
                </h3>
                <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-full border-2 border-brand-500 text-brand-500 transition-all group-open:rotate-45 group-open:border-accent-500 group-open:bg-accent-500 group-open:text-white">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6">
                <span class="block h-[2px] w-10 bg-accent-500 mb-4" />
                <p class="text-[15px] leading-relaxed text-ink-700">{f.a}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
</style>
