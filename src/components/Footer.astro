---
import { NAV_LINKS, SITE } from '@/consts';
const year = new Date().getFullYear();
---

<footer class="bg-brand-500 text-cream-200">
  <!-- Línea ámbar superior decorativa -->
  <div class="h-1 w-full bg-accent-500"></div>

  <div class="container py-14 lg:py-20">
    <div class="grid gap-10 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <a href="/" class="flex flex-col leading-none">
          <span class="font-display text-3xl font-black tracking-tight text-white">
            CÁMARA<span class="text-accent-500">.</span>SEGURIDAD
          </span>
          <span
            class="mt-1.5 text-[10px] font-bold uppercase tracking-[0.32em] text-cream-200/60"
          >
            CCTV · INSTALACIÓN · MONITOREO
          </span>
        </a>

        <p class="mt-6 text-[14.5px] leading-relaxed text-cream-200/85">
          Más de 10 años instalando sistemas CCTV en hogares, comercios e industrias de la
          Ciudad de México y Estado de México. Equipo Hikvision, Dahua y Provision-ISR — las mismas
          marcas que usan bancos y aeropuertos.
        </p>

        <div class="mt-6 flex items-center gap-3">
          <a
            href={SITE.social.facebook}
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
            class="grid h-10 w-10 place-items-center rounded-md bg-brand-600 text-cream-100 transition-colors hover:bg-accent-500 hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
                d="M22 12a10 10 0 1 0-11.5 9.9v-7H8V12h2.5V9.7c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12H16l-.4 2.9h-2.1v7A10 10 0 0 0 22 12Z"
              ></path>
            </svg>
          </a>
          <a
            href={SITE.social.instagram}
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="grid h-10 w-10 place-items-center rounded-md bg-brand-600 text-cream-100 transition-colors hover:bg-accent-500 hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"></circle>
            </svg>
          </a>
          <a
            href={SITE.social.youtube}
            target="_blank"
            rel="noopener"
            aria-label="YouTube"
            class="grid h-10 w-10 place-items-center rounded-md bg-brand-600 text-cream-100 transition-colors hover:bg-accent-500 hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
                d="M23 12s0-3.3-.4-4.9a2.5 2.5 0 0 0-1.8-1.8C19 5 12 5 12 5s-7 0-8.8.3A2.5 2.5 0 0 0 1.4 7.1C1 8.7 1 12 1 12s0 3.3.4 4.9a2.5 2.5 0 0 0 1.8 1.8C5 19 12 19 12 19s7 0 8.8-.3a2.5 2.5 0 0 0 1.8-1.8C23 15.3 23 12 23 12ZM10 15V9l5 3-5 3Z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.18em] text-white">Navegación</h3>
        <span class="mt-3 block h-[3px] w-8 bg-accent-500"></span>
        <ul class="mt-5 space-y-2.5 text-[14.5px]">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a href={link.href} class="text-cream-200/80 hover:text-accent-400">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.18em] text-white">Contacto</h3>
        <span class="mt-3 block h-[3px] w-8 bg-accent-500"></span>
        <ul class="mt-5 space-y-3 text-[14.5px]">
          <li>
            <a
              href={`https://wa.me/${SITE.contact.whatsapp}`}
              target="_blank"
              rel="noopener"
              class="flex items-start gap-2 text-cream-200/80 hover:text-accent-400"
            >
              <span class="mt-0.5 text-accent-500">●</span>
              <span>WhatsApp · {SITE.contact.whatsappDisplay}</span>
            </a>
          </li>
          <li>
            <a
              href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`}
              class="flex items-start gap-2 text-cream-200/80 hover:text-accent-400"
            >
              <span class="mt-0.5 text-accent-500">●</span>
              <span>{SITE.contact.phone}</span>
            </a>
          </li>
          <li>
            <a
              href={`mailto:${SITE.contact.email}`}
              class="flex items-start gap-2 text-cream-200/80 hover:text-accent-400"
            >
              <span class="mt-0.5 text-accent-500">●</span>
              <span>{SITE.contact.email}</span>
            </a>
          </li>
          <li class="flex items-start gap-2 text-cream-200/80">
            <span class="mt-0.5 text-accent-500">●</span>
            <span>{SITE.contact.hours}</span>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-brand-400/40 pt-8 text-xs text-cream-200/60 sm:flex-row sm:items-center"
    >
      <p>© {year} {SITE.business.legalName}. Todos los derechos reservados.</p>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        <a href="/aviso-de-privacidad" class="hover:text-accent-400">Aviso de privacidad</a>
        <a href="/terminos" class="hover:text-accent-400">Términos y condiciones</a>
      </div>
    </div>
  </div>
</footer>
