---
import { SERVICE_LINKS, SECTION_LINKS, SITE } from '@/consts';
const year = new Date().getFullYear();

const serviceIcons: Record<string, string> = {
  '/servicios/camaras-para-hogar/':          '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  '/servicios/camaras-para-comercio/':       '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/>',
  '/servicios/sistemas-cctv-industriales/':     '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/>',
  '/servicios/control-de-acceso/': '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
};
---

<footer class="bg-brand-500 text-cream-200">
  <!-- Franja roja superior -->
  <div class="h-1 w-full bg-accent-500"></div>

  <div class="container py-14 lg:py-20">

    <!-- ── FILA PRINCIPAL ────────────────────────────────────── -->
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.8fr_1fr_1fr_1.2fr]">

      <!-- Columna 1 — Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="group inline-flex flex-col leading-none transition-opacity hover:opacity-85">
          <span class="font-display text-3xl font-black tracking-tight text-white">
            CÁMARA<span class="text-accent-500">.</span>SEGURIDAD
          </span>
          <span class="mt-1.5 text-[9.5px] font-bold uppercase tracking-[0.3em] text-cream-200/55">
            CCTV · INSTALACIÓN · MONITOREO
          </span>
        </a>

        <p class="mt-5 max-w-sm text-[14px] leading-relaxed text-cream-200/80">
          Más de 10 años instalando sistemas CCTV en hogares, comercios e industrias de CDMX y
          Estado de México. Hikvision, Dahua y Provision-ISR — las mismas marcas que usan bancos
          y aeropuertos.
        </p>

        <!-- Social -->
        <div class="mt-6 flex items-center gap-2.5">
          <a href={SITE.social.facebook} target="_blank" rel="noopener" aria-label="Facebook"
            class="grid h-9 w-9 place-items-center rounded-lg bg-white/10 text-cream-100 transition-all hover:bg-accent-500 hover:text-white hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4.5 w-4.5" aria-hidden="true">
              <path d="M22 12a10 10 0 1 0-11.5 9.9v-7H8V12h2.5V9.7c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12H16l-.4 2.9h-2.1v7A10 10 0 0 0 22 12Z"/>
            </svg>
          </a>
          <a href={SITE.social.instagram} target="_blank" rel="noopener" aria-label="Instagram"
            class="grid h-9 w-9 place-items-center rounded-lg bg-white/10 text-cream-100 transition-all hover:bg-accent-500 hover:text-white hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4.5 w-4.5" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </a>
          <a href={SITE.social.youtube} target="_blank" rel="noopener" aria-label="YouTube"
            class="grid h-9 w-9 place-items-center rounded-lg bg-white/10 text-cream-100 transition-all hover:bg-accent-500 hover:text-white hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4.5 w-4.5" aria-hidden="true">
              <path d="M23 12s0-3.3-.4-4.9a2.5 2.5 0 0 0-1.8-1.8C19 5 12 5 12 5s-7 0-8.8.3A2.5 2.5 0 0 0 1.4 7.1C1 8.7 1 12 1 12s0 3.3.4 4.9a2.5 2.5 0 0 0 1.8 1.8C5 19 12 19 12 19s7 0 8.8-.3a2.5 2.5 0 0 0 1.8-1.8C23 15.3 23 12 23 12ZM10 15V9l5 3-5 3Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Columna 2 — Servicios -->
      <div>
        <h3 class="text-[10.5px] font-bold uppercase tracking-[0.22em] text-white">Servicios</h3>
        <span class="mt-3 block h-[3px] w-8 rounded-full bg-accent-500"></span>
        <ul class="mt-5 space-y-2">
          {SERVICE_LINKS.map((link) => (
            <li>
              <a href={link.href} class="group/item flex items-center gap-2.5 text-[13.5px] text-cream-200/75 transition-colors hover:text-white">
                <span class="grid h-6 w-6 shrink-0 place-items-center rounded-md bg-white/8 text-cream-200/60 transition-colors group-hover/item:bg-accent-500 group-hover/item:text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true" set:html={serviceIcons[link.href] ?? ''}/>
                </span>
                {link.label}
              </a>
            </li>
          ))}
          <li class="pt-1">
            <a href="/servicios/" class="inline-flex items-center gap-1 text-[12px] font-bold text-accent-400 transition-colors hover:text-accent-300">
              Ver todos
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 3 — Páginas y secciones -->
      <div>
        <h3 class="text-[10.5px] font-bold uppercase tracking-[0.22em] text-white">Empresa</h3>
        <span class="mt-3 block h-[3px] w-8 rounded-full bg-accent-500"></span>
        <ul class="mt-5 space-y-2">
          {SECTION_LINKS.map((link) => (
            <li>
              <a href={link.href} class="flex items-center gap-2 text-[13.5px] text-cream-200/75 transition-colors hover:text-white">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 shrink-0 text-accent-500/60" aria-hidden="true">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 4 — Contacto con iconos SVG reales -->
      <div>
        <h3 class="text-[10.5px] font-bold uppercase tracking-[0.22em] text-white">Contacto</h3>
        <span class="mt-3 block h-[3px] w-8 rounded-full bg-accent-500"></span>
        <ul class="mt-5 space-y-3">

          <!-- WhatsApp -->
          <li>
            <a
              href={`https://wa.me/${SITE.contact.whatsapp}`}
              target="_blank"
              rel="noopener"
              class="group/c flex items-start gap-3 text-[13.5px] text-cream-200/75 transition-colors hover:text-white"
            >
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-white/10 text-accent-400 transition-colors group-hover/c:bg-accent-500 group-hover/c:text-white">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
              </span>
              <span>WhatsApp · {SITE.contact.whatsappDisplay}</span>
            </a>
          </li>

          <!-- Teléfono -->
          <li>
            <a
              href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`}
              class="group/c flex items-start gap-3 text-[13.5px] text-cream-200/75 transition-colors hover:text-white"
            >
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-white/10 text-cream-200/50 transition-colors group-hover/c:bg-accent-500 group-hover/c:text-white">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.92 3.42 2 2 0 0 1 3.9 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/>
                </svg>
              </span>
              <span>{SITE.contact.phone}</span>
            </a>
          </li>

          <!-- Email -->
          <li>
            <a
              href={`mailto:${SITE.contact.email}`}
              class="group/c flex items-start gap-3 text-[13.5px] text-cream-200/75 transition-colors hover:text-white"
            >
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-white/10 text-cream-200/50 transition-colors group-hover/c:bg-accent-500 group-hover/c:text-white">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </span>
              <span class="break-all">{SITE.contact.email}</span>
            </a>
          </li>

          <!-- Horario -->
          <li class="flex items-start gap-3 text-[13.5px] text-cream-200/75">
            <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-white/10 text-cream-200/50">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </span>
            <span>{SITE.contact.hours}</span>
          </li>

          <!-- Dirección -->
          <li class="flex items-start gap-3 text-[13.5px] text-cream-200/75">
            <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-white/10 text-cream-200/50">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <span>{SITE.contact.address}</span>
          </li>
        </ul>

        <!-- CTA WhatsApp -->
        <a
          href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent('Hola, quiero una cotización gratuita.')}`}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center gap-2 rounded-lg bg-accent-500 px-4 py-2.5 text-[13px] font-bold text-white shadow-[0_2px_8px_rgba(220,38,38,0.4)] transition-all hover:bg-accent-600 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(220,38,38,0.45)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Cotización gratis
        </a>
      </div>
    </div>

    <!-- ── ACCESOS RÁPIDOS ──────────────────────────────────── -->
    <div class="mt-12 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-6">
      {SECTION_LINKS.map((link) => (
        <a
          href={link.href}
          class="group/q flex items-center justify-center gap-1.5 rounded-xl border border-white/8 bg-white/5 px-3 py-3 text-center text-[12px] font-semibold text-cream-200/65 transition-all hover:border-accent-500/40 hover:bg-white/10 hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 shrink-0 text-accent-500/50 transition-colors group-hover/q:text-accent-400" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
          {link.label}
        </a>
      ))}
    </div>

    <!-- ── LEGAL ─────────────────────────────────────────────── -->
    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-white/10 pt-8 text-[12px] text-cream-200/45 sm:flex-row sm:items-center">
      <p>© {year} {SITE.business.legalName}. Todos los derechos reservados.</p>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        <a href="/aviso-de-privacidad" class="transition-colors hover:text-accent-400">Aviso de privacidad</a>
        <a href="/terminos" class="transition-colors hover:text-accent-400">Términos y condiciones</a>
      </div>
    </div>
  </div>
</footer>
