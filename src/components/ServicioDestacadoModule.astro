---
/**
 * Módulo destacado de 2 columnas para un servicio individual.
 * Va en el index, debajo del grid de 4 cards de servicios.
 * Reusable: se llama 1x por servicio (residencial, comercial, etc.).
 */

interface StatEntry {
  value: string;
  label: string;
}

interface Props {
  eyebrow: string;
  title: string;
  introHtml: string;
  paragraphsHtml: string[];
  paragraphsTitle: string;
  stats: StatEntry[];
  icon: 'home' | 'store' | 'factory' | 'lock' | 'camera' | 'ptz' | 'thermal' | 'lpr';
  color: 'brand' | 'accent';
  ctaDetalleUrl: string;
}

const {
  eyebrow,
  title,
  introHtml,
  paragraphsHtml,
  paragraphsTitle,
  stats,
  icon,
  color,
  ctaDetalleUrl,
} = Astro.props;

const isBrand = color === 'brand';
const headerBg = isBrand ? 'bg-brand-500' : 'bg-accent-500';
const ctaTextColor = isBrand ? 'text-brand-500' : 'text-accent-500';

const icons: Record<string, string> = {
  home: '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  store:
    '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/><path d="M9 13a3 3 0 1 0 6 0"/>',
  factory:
    '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/><path d="M7 17h2M11 17h2M15 17h2"/>',
  lock: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
  camera:
    '<path d="M3 8a2 2 0 0 1 2-2h3l2-2h4l2 2h3a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z"/><circle cx="12" cy="13" r="4"/><path d="M17 8h.01"/>',
  ptz: '<circle cx="12" cy="12" r="9"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/><circle cx="12" cy="12" r="3"/>',
  thermal:
    '<path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4 4 0 1 0 5 0Z"/><path d="M12 9v6"/>',
  lpr: '<path d="M5 13l2-5h10l2 5"/><path d="M5 13v5h2v-2h10v2h2v-5z"/><circle cx="8" cy="16" r="1"/><circle cx="16" cy="16" r="1"/>',
};
---

<section class="bg-cream-100 py-6 lg:py-8">
  <div class="container">
    <article class="card grid overflow-hidden lg:grid-cols-2">
      <!-- COLUMNA IZQUIERDA — bloque de color sólido -->
      <div class={`${headerBg} relative overflow-hidden p-8 sm:p-12 lg:p-16`}>
        <div
          class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-white/5"
          aria-hidden="true"
        ></div>
        <div
          class="absolute right-24 top-40 h-32 w-32 rounded-full bg-white/5"
          aria-hidden="true"
        ></div>

        <div class="relative">
          <span class="grid h-14 w-14 place-items-center rounded-lg bg-white/15">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-7 w-7 text-white"
              aria-hidden="true"
              set:html={icons[icon]}
            />
          </span>

          <p class="mt-6 text-[10px] font-bold uppercase tracking-[0.32em] text-white/70">
            Servicio destacado
          </p>
          <p class={`mt-2 text-[11px] font-bold uppercase tracking-[0.22em] ${isBrand ? 'text-accent-400' : 'text-white'}`}>
            ● {eyebrow}
          </p>

          <h2 class="mt-3 font-display text-3xl font-black leading-[1.05] text-white sm:text-4xl lg:text-5xl">
            {title}
          </h2>

          <span class={`mt-5 block h-[3px] w-12 rounded-full ${isBrand ? 'bg-accent-500' : 'bg-white/60'}`}></span>

          <p
            class="mt-6 max-w-md text-[15.5px] leading-relaxed text-white/90"
            set:html={introHtml}
          />

          <div class="mt-8 grid grid-cols-2 gap-3 sm:gap-4">
            {
              stats.map((s) => (
                <div class="rounded-lg border border-white/15 bg-white/5 p-4 backdrop-blur">
                  <p class="font-display text-2xl font-black leading-none text-white sm:text-3xl">
                    {s.value}
                  </p>
                  <p class="mt-2 text-[10px] font-bold uppercase tracking-wider text-white/70">
                    {s.label}
                  </p>
                </div>
              ))
            }
          </div>

          <a
            href={ctaDetalleUrl}
            class={`mt-8 inline-flex items-center gap-2 rounded-md bg-white px-6 py-3 text-[14.5px] font-bold ${ctaTextColor} transition-all hover:bg-cream-50 hover:shadow-card`}
          >
            Ver servicio completo
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- COLUMNA DERECHA — descripción en prosa unificada -->
      <div class="flex flex-col bg-white p-8 sm:p-12 lg:p-16">
        <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-accent-500">
          ● Paquetes disponibles
        </p>
        <h3 class="mt-3 font-display text-2xl font-black leading-tight text-brand-500 sm:text-3xl">
          {paragraphsTitle}
        </h3>
        <span class="marker-line mt-5"></span>

        <div class="mt-7 flex-1 space-y-5 text-[15.5px] leading-[1.75] text-ink-700">
          {paragraphsHtml.map((p) => <p set:html={p} />)}
        </div>

        <div class="mt-8 border-t border-cream-200 pt-6">
          <a href="#contacto" class="btn-primary w-full sm:w-auto">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
                d="M20.5 3.5A11.4 11.4 0 0 0 12.3 0C5.9 0 .7 5.2.7 11.6c0 2 .5 4 1.5 5.8L0 24l6.8-1.8a11.6 11.6 0 0 0 5.5 1.4h.1c6.4 0 11.6-5.2 11.6-11.6 0-3.1-1.2-6-3.4-8.3Z"
              ></path>
            </svg>
            Cotizar por WhatsApp
          </a>
          <p class="mt-3 text-[12px] text-ink-600">
            Te respondemos en menos de 15 minutos · cotización gratis · visita técnica sin costo
          </p>
        </div>
      </div>
    </article>
  </div>
</section>
