---
import type { CollectionEntry } from 'astro:content';

interface Props {
  servicios: CollectionEntry<'servicios'>[];
}

const { servicios } = Astro.props;

const icons: Record<string, string> = {
  home: '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  store:
    '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/><path d="M9 13a3 3 0 1 0 6 0"/>',
  factory:
    '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/><path d="M7 17h2M11 17h2M15 17h2"/>',
  lock: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
};
---

<section id="lineas" class="section-white">
  <div class="container">
    <div class="grid items-end gap-8 lg:grid-cols-[1fr_2fr] lg:gap-16">
      <div>
        <span class="eyebrow">Líneas de servicio</span>
        <h2 class="heading-lg mt-4 text-balance">
          Cuatro especialidades,
          <span class="text-accent-500">una sola filosofía</span>.
        </h2>
        <span class="marker-line mt-5"></span>
      </div>
      <p class="lead">
        Cada línea agrupa sus propias especialidades operativas. Selecciona la que aplica a tu caso
        para ver el detalle de cada sub-servicio incluido y entender qué cubrimos exactamente.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        servicios
          .sort((a, b) => a.data.orden - b.data.orden)
          .map((s) => {
            const isBrand = s.data.color === 'brand';
            const headerBg = isBrand ? 'bg-brand-500' : 'bg-accent-500';
            const slug = s.id.replace(/\.md$/, '');
            return (
              <article class="card group flex flex-col">
                {/* Header sólido */}
                <div class={`${headerBg} relative px-6 py-7`}>
                  <span class="grid h-14 w-14 place-items-center rounded-lg bg-white/15">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-7 w-7 text-white"
                      aria-hidden="true"
                      set:html={icons[s.data.icon]}
                    />
                  </span>
                  <p class="mt-5 text-[10px] font-bold uppercase tracking-[0.22em] text-white/80">
                    {s.data.eyebrow}
                  </p>
                  <h3 class="mt-2 font-display text-xl font-black leading-tight text-white">
                    {s.data.title}
                  </h3>
                </div>

                {/* Sub-servicios */}
                <ul class="flex-1">
                  {s.data.subServicios.slice(0, 4).map((sub) => (
                    <li>
                      <a href={sub.url} class="pkg-item">
                        <div>
                          <p class="text-[14px] font-bold text-brand-500">{sub.name}</p>
                          <p class="text-xs text-ink-600 line-clamp-2">{sub.description}</p>
                        </div>
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="h-4 w-4 shrink-0 text-cream-400 transition-all group-hover:text-accent-500"
                          aria-hidden="true"
                        >
                          <path d="M5 12h14" />
                          <path d="m12 5 7 7-7 7" />
                        </svg>
                      </a>
                    </li>
                  ))}
                </ul>

                <div class="px-5 pb-5 pt-3">
                  <a
                    href={`/servicios/${slug}/`}
                    class="btn-brand w-full uppercase tracking-wider text-xs"
                  >
                    Ver detalle completo
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-4 w-4"
                      aria-hidden="true"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </article>
            );
          })
      }
    </div>
  </div>
</section>
