---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ProcesoSection from '@components/ProcesoSection.astro';
import FaqSection from '@components/FaqSection.astro';
import CTASection from '@components/CTASection.astro';
import RelatedLinks from '@components/RelatedLinks.astro';
import { SITE } from '@/consts';
import { PAGE_SEO } from '@/data/seo';

const seo = PAGE_SEO['/como-trabajamos/'];

// HowTo schema — los 6 pasos del proceso
const howTo = {
  name: 'Cómo se instala un sistema de cámaras de seguridad CCTV profesional',
  description:
    'Proceso documentado de 6 pasos para instalar cámaras de seguridad CCTV con cableado oculto, app configurada y garantía 2 años por escrito.',
  totalTime: 'P3D',
  steps: [
    {
      name: 'Primer contacto y diagnóstico inicial',
      text: 'Nos escribes por WhatsApp o llamada. Un técnico certificado lee tu caso y responde en menos de 15 minutos con preguntas concretas para entender alcance y zona.',
    },
    {
      name: 'Visita técnica gratuita',
      text: 'Agendamos la visita en 24-48 horas. Recorremos el espacio, evaluamos accesos, identificamos puntos ciegos y analizamos infraestructura eléctrica y de cableado.',
    },
    {
      name: 'Propuesta y cotización por escrito',
      text: 'El mismo día entregamos un documento formal con marca, modelo, precio unitario, mano de obra, tiempo estimado y condiciones de garantía. Sin letra chica.',
    },
    {
      name: 'Programación e instalación profesional',
      text: 'Coordinamos fecha conveniente. Instalamos con cableado oculto, configuramos NVR/DVR, conectamos a tu red y verificamos cada cámara con planos entregados.',
    },
    {
      name: 'Configuración de app y capacitación',
      text: 'Instalamos la app oficial (Hik-Connect o DMSS) en hasta 3 dispositivos. Te capacitamos en vivo: ver en vivo, revisar grabaciones, configurar alertas.',
    },
    {
      name: 'Entrega formal y garantía firmada',
      text: 'Firmamos acta de entrega y garantía por escrito de 2 años en equipo y mano de obra. Te damos el WhatsApp directo del técnico responsable para soporte futuro.',
    },
  ],
};

const breadcrumb = [
  { name: 'Inicio', url: '/' },
  { name: 'Cómo trabajamos', url: '/como-trabajamos/' },
];

const faq = [
  {
    q: '¿Cuánto tiempo toma una instalación residencial completa?',
    a: 'Una instalación doméstica típica (4–8 cámaras) la completamos en 1 día hábil. Comercios medianos (8–16 cámaras) toman 1 a 2 días. Proyectos industriales o edificios se planifican en fases y los tiempos se especifican en la propuesta formal.',
  },
  {
    q: '¿Cobran por la visita técnica?',
    a: 'No. La visita técnica es completamente gratuita y sin compromiso de compra. Vamos a tu espacio, evaluamos los ángulos, la infraestructura eléctrica y el cableado, y regresamos con una propuesta escrita. Solo pagas si decides contratar.',
  },
  {
    q: '¿Puedo ver la cotización antes de dar un anticipo?',
    a: 'Sí, siempre. Recibes la cotización detallada por escrito — con marca, modelo, precio unitario, mano de obra y tiempo de instalación — antes de que te pidamos cualquier pago. No hay letras pequeñas ni cargos sorpresa.',
  },
  {
    q: '¿Qué pasa si algo falla después de la instalación?',
    a: 'Tienes 2 años de garantía en equipos y mano de obra. Si algo falla durante ese período, coordinamos la visita técnica, traemos la refacción y reparamos sin costo adicional. El soporte es por WhatsApp directo con el técnico — no un call center.',
  },
  {
    q: '¿Necesito estar presente durante toda la instalación?',
    a: 'Para el inicio de la instalación sí, para autorizar accesos y firmar el acta de inicio. Durante el trabajo puedes continuar con tus actividades normales. Al final del día te hacemos la entrega formal: prueba de cámaras, configuración de la app y firma de garantía.',
  },
  {
    q: '¿Cuánto tiempo lleva configurar la app en mi celular?',
    a: 'La configuración de la app (Hik-Connect, DMSS o similar según tu equipo) toma entre 15 y 30 minutos por dispositivo. La configuramos en hasta 3 dispositivos el mismo día de la instalación y te explicamos cada función antes de irnos.',
  },
  {
    q: '¿Qué pasa si necesito agregar cámaras en el futuro?',
    a: 'Lo dejamos previsto desde el diseño. El NVR/DVR que instalamos tiene capacidad de expansión y el cableado queda organizado para ello. Agregar cámaras es una visita técnica de unas horas — sin necesidad de rehacer todo el sistema.',
  },
  {
    q: '¿Tienen financiamiento o pago a meses?',
    a: 'Sí. Aceptamos pago con tarjeta de crédito a 3, 6 y 12 meses sin intereses (sujeto a promoción vigente de tu banco). También manejamos esquemas de anticipo del 50% al contratar y el resto a la entrega.',
  },
  {
    q: '¿Puedo cancelar antes de que inicien la instalación?',
    a: 'Sí, sin penalización. Si ya pagaste anticipo y cancelas antes de que lleguemos al site, te devolvemos el 100% en máximo 5 días hábiles. Una vez iniciada la instalación aplicamos políticas proporcionales según avance.',
  },
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical="/como-trabajamos/"
  breadcrumb={breadcrumb}
  faq={faq}
  howTo={howTo}
>

  <!-- ── 1. HERO ──────────────────────────────────────────────── -->
  <Hero
    eyebrow="PROCESO DE INSTALACIÓN · SIN SORPRESAS"
    preTitle="Así es como"
    title1="Instalamos tu"
    title2="Sistema CCTV"
    subtitle="paso a paso, con tiempos reales y garantía firmada."
    descriptionHtml={`Cada instalación sigue un proceso de <strong class="font-bold text-brand-500">6 pasos documentados</strong>
— desde la primera llamada hasta que activas tu app. Sabes exactamente qué sigue,
quién es responsable y cuánto tiempo toma. Sin improvisación,
<strong class="font-bold text-brand-500">sin cobros sorpresa</strong>.`}
    col2Eyebrow="Lo que garantizamos"
    col2Title="Transparencia total "
    col2TitleHighlight="en cada etapa"
    col2Paragraphs={[
      {
        html: `<strong class="font-bold text-brand-500">Antes de pagar un solo peso</strong>
tienes por escrito: los equipos con marca y modelo, el desglose de costos, el tiempo estimado
de instalación y las condiciones de garantía. La visita técnica es gratuita. La cotización es
gratuita. El compromiso empieza cuando tú lo decides.`,
      },
      {
        html: `<strong class="font-bold text-brand-500">El día que termina la instalación</strong>
tu app ya está configurada en hasta 3 dispositivos, ya sabes cómo ver grabaciones, recibir alertas
y gestionar usuarios. Salimos cuando tú te sientes seguro — no cuando nosotros queremos irnos.`,
      },
    ]}
    showRecBadge={true}
    showQuickLinks={true}
  />

  <!-- ── 2. PROCESO COMPLETO ──────────────────────────────────── -->
  <ProcesoSection />

  <!-- ── 3. COMPROMISO / TRUST STRIP ─────────────────────────── -->
  <section class="section-cream" id="compromiso">
    <div class="container">

      <div class="grid items-end gap-8 lg:grid-cols-[1fr_2fr] lg:gap-16">
        <div>
          <span class="eyebrow">Nuestro compromiso</span>
          <h2 class="heading-lg mt-4 text-balance">
            Lo que está incluido
            <span class="text-accent-500">en cada proyecto</span>
          </h2>
          <span class="marker-line mt-5"></span>
        </div>
        <div class="space-y-4">
          <p class="lead">
            No cobramos extras por las cosas que deberían ser estándar. Visita técnica, propuesta
            formal, capacitación presencial, configuración de app y garantía por escrito — todo
            incluido en cualquier proyecto, sin importar el tamaño.
          </p>
          <p class="text-[15.5px] leading-relaxed text-ink-600">
            Llevamos más de 50 años en el mercado y nuestra mejor publicidad son las
            recomendaciones de boca en boca. Eso solo pasa cuando la experiencia del cliente
            es buena de principio a fin — no solo el día de la instalación.
          </p>
        </div>
      </div>

      <!-- Grid de compromisos -->
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />`,
            title: 'Respuesta en menos de 15 min',
            desc: 'WhatsApp directo con el asesor asignado a tu proyecto. No es un bot ni un call center — es una persona real que conoce tu caso.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />`,
            title: '2 años de garantía por escrito',
            desc: 'Equipos y mano de obra. Si algo falla durante el periodo, lo resolvemos sin costo: visita, refacción y mano de obra incluidas.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12-3-3m0 0-3 3m3-3v6m-1.5-15H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />`,
            title: 'Propuesta formal antes de pagar',
            desc: 'Marca, modelo, precio unitario, mano de obra, tiempo estimado y condiciones de garantía — todo por escrito antes de que pagues un centavo.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 3h3m-3 3h3" />`,
            title: 'App configurada el mismo día',
            desc: 'No te entregamos un sistema a medias. Instalamos la app en hasta 3 dispositivos, configuramos alertas y te explicamos cada función presencialmente.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />`,
            title: 'Técnicos certificados con identificación',
            desc: 'Cada técnico tiene certificación oficial Hikvision o Dahua y se presenta con identificación. Sabes quién entra a tu propiedad y cómo contactarlo.',
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />`,
            title: 'Sin contrato de permanencia',
            desc: 'No hay mensualidad ni contrato forzoso. Pagas el proyecto una sola vez y el sistema es tuyo. El soporte post-venta es incluido en la garantía.',
          },
        ].map((item) => (
          <article class="card group flex flex-col gap-4 p-6 transition-all hover:-translate-y-0.5 hover:shadow-card">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/8 text-brand-500 transition-colors group-hover:bg-brand-500 group-hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                <Fragment set:html={item.icon} />
              </svg>
            </span>
            <div>
              <h3 class="font-display text-[16px] font-black text-brand-500 transition-colors group-hover:text-accent-500">
                {item.title}
              </h3>
              <p class="mt-2 text-[13.5px] leading-relaxed text-ink-600">{item.desc}</p>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ── 4. STATS BAND ───────────────────────────────────────── -->
  <section class="bg-brand-500 py-12 lg:py-14" aria-label="Cifras del proceso">
    <div class="container">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:gap-6">
        {[
          { val: '3 días', lbl: 'instalación residencial promedio' },
          { val: '<15 min', lbl: 'tiempo de primera respuesta' },
          { val: '2 años', lbl: 'garantía en equipo y mano de obra' },
          { val: '15,000+', lbl: 'proyectos entregados desde 1976' },
        ].map((s) => (
          <div class="rounded-xl border border-white/10 bg-white/5 p-5 text-center">
            <p class="font-display text-3xl font-black leading-none text-white sm:text-4xl">{s.val}</p>
            <p class="mt-2 text-[11.5px] font-semibold uppercase tracking-wider text-cream-300">{s.lbl}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 5. COMPARATIVA: con nosotros vs. sin proceso ────────── -->
  <section class="section-white" id="comparativa">
    <div class="container">

      <div class="grid items-end gap-8 lg:grid-cols-[1fr_2fr] lg:gap-16">
        <div>
          <span class="eyebrow">Por qué importa el proceso</span>
          <h2 class="heading-lg mt-4 text-balance">
            Con proceso vs.
            <span class="text-accent-500">sin proceso</span>
          </h2>
          <span class="marker-line mt-5"></span>
        </div>
        <div class="space-y-4">
          <p class="lead">
            El 80% de los problemas post-instalación en CCTV provienen de sistemas instalados
            sin visita técnica previa, sin diseño formal y sin entrega documentada. No es mala
            suerte — es consecuencia directa de saltarse pasos.
          </p>
          <p class="text-[15.5px] leading-relaxed text-ink-600">
            Un sistema bien instalado con proceso formal dura 7–10 años sin problemas mayores.
            Uno instalado "a la rápida" suele generar re-trabajo, cámaras en mal ángulo y fallas
            en grabación a los 12–18 meses.
          </p>
        </div>
      </div>

      <div class="mt-14 overflow-hidden rounded-2xl border border-cream-200">
        <!-- Header -->
        <div class="grid grid-cols-[1.2fr_1fr_1fr] bg-brand-500 text-[11px] font-bold uppercase tracking-[0.2em] text-cream-200">
          <div class="px-6 py-4">Punto de falla común</div>
          <div class="border-l border-white/10 px-6 py-4 text-accent-300">Con nuestro proceso</div>
          <div class="border-l border-white/10 px-6 py-4">Sin proceso formal</div>
        </div>
        {[
          { punto: 'Cámaras en ángulo incorrecto', con: 'Diseño de cobertura previo a la instalación', sin: 'Se detecta hasta que ocurre el incidente' },
          { punto: 'Cableado visible o mal hecho', con: 'Plano de cableado y acabado incluido en propuesta', sin: 'Cable visible, sin etiquetas, difícil de mantener' },
          { punto: 'App que no funciona remotamente', con: 'Configuración completa el mismo día de entrega', sin: 'El técnico no vuelve a configurarla' },
          { punto: 'Equipo que falla en 12 meses', con: 'Marcas certificadas + 2 años de garantía por escrito', sin: 'Garantía verbal, refacciones por cuenta propia' },
          { punto: 'No saber usar el sistema', con: 'Capacitación presencial antes de la entrega final', sin: 'Manual en PDF, sin seguimiento' },
          { punto: 'Sin soporte posterior', con: 'WhatsApp directo con técnico asignado', sin: 'Número que ya no contesta' },
        ].map((row, i) => (
          <div class={`grid grid-cols-[1.2fr_1fr_1fr] border-t border-cream-100 ${i % 2 === 1 ? 'bg-cream-50' : 'bg-white'}`}>
            <div class="px-6 py-4 text-[13px] font-semibold text-ink-700">{row.punto}</div>
            <div class="flex items-start gap-2 border-l border-cream-100 px-6 py-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 shrink-0 text-accent-500" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-[13px] text-ink-700">{row.con}</span>
            </div>
            <div class="flex items-start gap-2 border-l border-cream-100 px-6 py-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 shrink-0 text-ink-300" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
              <span class="text-[13px] text-ink-400">{row.sin}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── 6. FAQ ────────────────────────────────────────────────── -->
  <FaqSection faqs={faq} />

  <!-- ── 6.5 ENLAZADO INTERNO ────────────────────────────────── -->
  <RelatedLinks variant="cream" eyebrow="Profundiza en lo que ofrecemos" />

  <!-- ── 7. CTA ────────────────────────────────────────────────── -->
  <CTASection />

</BaseLayout>
