---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe o fue movida."
  noindex
>
  <section class="section-cream">
    <div class="container">
      <div class="mx-auto max-w-xl text-center">
        <p class="font-display text-7xl font-black text-accent-500 sm:text-8xl">404</p>
        <h1 class="heading-md mt-4">Esta página no existe</h1>
        <span class="marker-line mx-auto mt-5"></span>
        <p class="lead mt-5">
          La dirección que ingresaste no se encuentra en nuestro sitio. Vuelve al inicio y te
          ayudamos a encontrar lo que necesitas.
        </p>
        <a href="/" class="btn-primary mt-8">Volver al inicio</a>
      </div>
    </div>
  </section>
</BaseLayout>
