---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CTASection from '@components/CTASection.astro';
import { SITE } from '@/consts';

const breadcrumb = [
  { name: 'Inicio', url: '/' },
  { name: 'Preguntas frecuentes', url: '/faq/' },
];

interface FaqItem {
  q: string;
  a: string;
}

interface FaqCategory {
  id: string;
  label: string;
  icon: string;
  color: string;
  items: FaqItem[];
}

const categorias: FaqCategory[] = [
  {
    id: 'precios',
    label: 'Precios y cotización',
    color: 'emerald',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />',
    items: [
      {
        q: '¿Cuánto cuesta instalar cámaras de seguridad en mi casa?',
        a: 'Una instalación residencial estándar de 4 cámaras HD con NVR de 8 canales, cableado oculto, app configurada y garantía 2 años parte desde $7,900 MXN (equipo + instalación + mano de obra). El precio exacto depende del número de cámaras, la distribución del espacio, el tipo de cableado y si se necesita apertura de canales en muros. La cotización es gratis y por escrito — nunca cobramos de más sin explicar por qué.',
      },
      {
        q: '¿Por qué los precios varían tanto entre instaladores?',
        a: 'Porque no todos instalan lo mismo. La diferencia está en la marca del equipo (genérico vs. Hikvision/Dahua), el tipo de cableado (superficial vs. oculto), si hacen o no visita técnica previa, si incluyen la app configurada y qué garantía ofrecen. Un sistema "barato" sin visita técnica, con cámara genérica y sin garantía escrita, cuesta menos hoy y mucho más en 18 meses. Siempre pide que te especifiquen la marca y modelo del equipo antes de comparar precios.',
      },
      {
        q: '¿Cobran por la visita técnica?',
        a: 'No. La visita técnica es completamente gratuita y sin compromiso de compra. Vamos a tu espacio, evaluamos ángulos, puntos ciegos e infraestructura, diseñamos el plano de distribución y te entregamos una cotización por escrito ese mismo día. Solo pagas si decides contratar. El 73% de nuestros clientes proceden después de la visita — no porque los presionemos, sino porque la propuesta habla por sí sola.',
      },
      {
        q: '¿Qué formas de pago aceptan?',
        a: 'Aceptamos efectivo, transferencia bancaria y tarjeta de crédito o débito. Con tarjeta de crédito podemos procesar pagos a 3, 6 y 12 meses sin intereses sujeto a la promoción vigente de tu banco. El esquema habitual es 50% de anticipo al contratar y 50% a la entrega y activación del sistema. Sin pagos ocultos ni cargos de última hora.',
      },
      {
        q: '¿Hay cargos adicionales que no aparezcan en la cotización?',
        a: 'No. La cotización incluye equipo, cableado, mano de obra, accesorios de montaje, configuración de app y garantía. Si durante la instalación encontramos una situación no prevista que requiera trabajo adicional (por ejemplo, una pared con material especial), te notificamos antes de proceder y te damos el costo extra por escrito. Nunca cobramos sorpresas al final.',
      },
      {
        q: '¿Puedo pagar en parcialidades o hay financiamiento?',
        a: 'Sí. Además del esquema 50/50 estándar, manejamos el pago en tarjeta a meses sin intereses. Para proyectos industriales o de gran escala podemos negociar esquemas por avance de obra con pagos en 3 etapas. Contáctanos para discutir la opción que mejor se ajuste a tu flujo de caja.',
      },
    ],
  },
  {
    id: 'instalacion',
    label: 'Proceso de instalación',
    color: 'blue',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />',
    items: [
      {
        q: '¿Cuánto tiempo tarda la instalación completa?',
        a: 'Un sistema residencial de 4 cámaras lo completamos en 1 día (4–8 horas según la complejidad del cableado). Un comercio mediano con 8 cámaras toma 6–10 horas. Proyectos industriales o multisitio se planifican en fases con fechas definidas en la propuesta. En todos los casos, el mismo día que terminamos la instalación configuramos la app y hacemos la entrega formal. No dejamos "trabajo pendiente para mañana".',
      },
      {
        q: '¿Necesito estar presente durante toda la instalación?',
        a: 'Para el inicio necesitamos que estés presente 15–20 minutos para autorizar el acceso, firmar el acta de inicio y confirmar la distribución del sistema. Durante el trabajo puedes continuar con tus actividades normales. Al final (entrega) sí pedimos que estés presente: revisamos cada cámara contigo, configuramos la app en tu celular y firmamos la garantía.',
      },
      {
        q: '¿Hacen perforaciones en paredes? ¿Cómo queda el acabado?',
        a: 'Sí, el cableado profesional requiere perforaciones para pasar el cable oculto. Nuestros técnicos trabajan con taladros de punta delgada, sellamos los puntos de paso con silicón blanco o gris según el color de la pared y dejamos el área limpia. El resultado es un cableado que no se ve: por dentro de plafones, por dentro de muros o en canaleta de PVC empotrada según el tipo de construcción.',
      },
      {
        q: '¿Puedo agregar más cámaras después sin rehacer todo?',
        a: 'Sí, si el NVR tiene canales libres. Por eso recomendamos instalar un grabador con el doble de canales del número inicial de cámaras — así puedes escalar sin cambiar el equipo central. En la visita técnica te especificamos exactamente cuánto margen de crecimiento queda en la propuesta. También dejamos el cableado etiquetado para que sea sencillo extender el sistema en el futuro.',
      },
      {
        q: '¿Qué pasa si mi propiedad tiene caseta de acceso o protocolo de seguridad?',
        a: 'Es muy común, sobre todo en fraccionamientos y corporativos. Solo necesitamos que registres al técnico como visitante el día anterior. El técnico llega con identificación oficial, tarjeta de presentación de la empresa y, si se requiere, podemos enviar una carta de trabajo firmada. En instalaciones con protocolos estrictos (bancos, plazas comerciales), coordinamos todo con anticipación.',
      },
      {
        q: '¿Trabajan en fines de semana o fuera de horario hábil?',
        a: 'Sí. Atendemos de lunes a sábado de 9:00 a 19:00. Para proyectos comerciales donde no podemos trabajar en horario de apertura (restaurantes, tiendas, oficinas) podemos hacer la instalación en horario fuera de operación con costo adicional de mano de obra nocturna. Consulta disponibilidad al agendar.',
      },
    ],
  },
  {
    id: 'equipos',
    label: 'Equipos y tecnología',
    color: 'violet',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />',
    items: [
      {
        q: '¿Qué marcas de cámaras instalan y por qué solo esas?',
        a: 'Trabajamos exclusivamente con Hikvision, Dahua y Provision-ISR — las mismas marcas que usan bancos, aeropuertos, hoteles y cadenas de supermercados. Estas marcas tienen certificación internacional, refacciones disponibles en México, soporte técnico local y actualizaciones de firmware activas. Las marcas genéricas que se venden "baratas" en línea suelen fallar antes de los 18 meses, no tienen refacciones y sus apps dejan de funcionar cuando el servidor en China se cae. Nunca instalamos lo que no usaríamos en nuestra propia propiedad.',
      },
      {
        q: '¿Cuál es la diferencia entre cámaras IP y cámaras análogas?',
        a: 'Las cámaras IP transmiten la imagen en digital por cable de red (UTP) o Wi-Fi, ofrecen mayor resolución (4–8 MP), analítica de video inteligente (detección de personas, vehículos, intrusión en zona) y configuración granular. Las análogas (HD-TVI, HD-CVI) transmiten por cable coaxial y son más sencillas y económicas, ideales para instalaciones donde la imagen básica es suficiente. En la visita técnica te recomendamos cuál aplica a tu caso sin preferencia de comisión.',
      },
      {
        q: '¿Las cámaras graban de noche y con poca luz?',
        a: 'Sí. Todas las cámaras que instalamos tienen visión nocturna infrarroja (IR) con alcance de 20 a 60 metros según modelo. Para entornos con cero luz natural (bodegas oscuras, estacionamientos cerrados) instalamos cámaras con iluminador IR de alta potencia o cámaras con tecnología Starlight que graban en color con iluminación mínima. El tipo adecuado se define en la visita técnica.',
      },
      {
        q: '¿Cuántos días hacia atrás puedo revisar grabaciones?',
        a: 'Depende del número de cámaras, la resolución configurada y la capacidad del disco duro. Un sistema típico de 4 cámaras en 2MP con disco de 1TB almacena entre 20 y 30 días de grabación continua. En la propuesta te especificamos exactamente cuántos días de respaldo tendrá tu sistema según la configuración elegida. Si necesitas más días, instalamos discos de mayor capacidad o configuramos grabación por movimiento para extender el almacenamiento.',
      },
      {
        q: '¿Qué resolución tienen las cámaras que instalan?',
        a: 'Depende del proyecto y el presupuesto. La entrada de línea es 2 MP (Full HD 1080p), que es suficiente para la mayoría de aplicaciones residenciales y comerciales. Para comercios donde se requiere identificación de rostros o lectura de matrículas usamos 4 MP. Para proyectos industriales, bancarios o de vigilancia perimetral de largo alcance usamos 4–8 MP. Nunca instalamos resoluciones menores a 2 MP.',
      },
      {
        q: '¿Necesito internet para que funcionen las cámaras?',
        a: 'No para las funciones básicas. Las cámaras graban en el NVR/DVR local sin necesidad de internet — puedes ver las grabaciones en el monitor conectado aunque no tengas señal. Internet es necesario únicamente para el acceso remoto desde tu celular o para las alertas de movimiento. Si pierdes la señal de internet, el sistema sigue grabando normalmente y cuando se restablece la conexión puedes acceder sin haber perdido ningún registro.',
      },
    ],
  },
  {
    id: 'garantia',
    label: 'Garantía y soporte',
    color: 'amber',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />',
    items: [
      {
        q: '¿Qué incluye exactamente la garantía de 2 años?',
        a: 'Cubre equipo (cámaras, NVR/DVR, fuentes de poder, cableado y accesorios de montaje) y mano de obra. Si cualquier componente falla por defecto de fábrica o por la instalación durante los 2 años, mandamos técnico, aportamos la refacción y reparamos sin costo adicional — incluyendo la visita. La garantía es por escrito, firmada por ambas partes antes de que pagues. No es verbal, no es "hasta donde aplique" y no tiene exclusiones de letra chica. Es el doble del estándar del mercado (6–12 meses).',
      },
      {
        q: '¿Qué pasa si una cámara falla fuera del horario hábil?',
        a: 'Atendemos urgencias de lunes a sábado de 9:00 a 19:00 por WhatsApp directo con el técnico asignado a tu proyecto. Para incidentes fuera de horario, dejamos un número de emergencias para casos críticos (robo en progreso, sistema caído completo). La primera respuesta siempre es remota (diagnóstico por video o acceso al sistema); si se requiere visita, la agendamos para el siguiente día hábil o el mismo día si la urgencia lo amerita.',
      },
      {
        q: '¿Ofrecen mantenimiento preventivo?',
        a: 'Sí, de forma opcional. Ofrecemos planes de mantenimiento semestral o anual que incluyen: limpieza de ópticas y carcasas, revisión de fijaciones y cableado, actualización de firmware, revisión de espacio en disco y ajuste de ángulos si han cambiado. El mantenimiento preventivo extiende la vida útil del sistema y previene el 90% de las fallas. No es obligatorio — es un servicio adicional que puedes contratar cuando quieras.',
      },
      {
        q: '¿Cómo funciona el soporte técnico después de la instalación?',
        a: 'Soporte directo por WhatsApp con el técnico que instaló tu sistema, no un call center. Respondemos en menos de 15 minutos en horario hábil. Para problemas de configuración de app, pérdida de contraseña o ajustes remotos, lo resolvemos por WhatsApp en menos de 30 minutos la mayoría de las veces. Para fallas físicas que requieren visita, agendamos dentro de las siguientes 24 horas.',
      },
      {
        q: '¿Trabajan con contrato de permanencia o mensualidad obligatoria?',
        a: 'No. Pagas tu sistema una sola vez y es tuyo — sin contratos de 24 o 36 meses, sin mensualidades forzosas, sin letras pequeñas. El monitoreo remoto 24/7 es un servicio completamente opcional: si lo quieres lo agregas cuando quieras y si ya no lo necesitas lo cancelas sin penalización. Somos transparentes desde el inicio porque sabemos que la confianza se gana con hechos, no con contratos.',
      },
    ],
  },
  {
    id: 'app',
    label: 'App y acceso remoto',
    color: 'sky',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 3h3m-3 3h3" />',
    items: [
      {
        q: '¿Puedo ver las cámaras desde mi celular en cualquier parte del mundo?',
        a: 'Sí, desde cualquier lugar con conexión a internet. Configuramos la app oficial (Hik-Connect para Hikvision, gDMSS/iDMSS para Dahua) en hasta 3 dispositivos iOS o Android el mismo día de la instalación. Puedes ver las cámaras en vivo, reproducir grabaciones de los últimos días, tomar capturas de pantalla y descargar clips de video. La app también funciona desde PC o tablet mediante navegador web.',
      },
      {
        q: '¿Cuántos usuarios o celulares pueden acceder al sistema?',
        a: 'La cuenta principal puede compartir acceso a usuarios secundarios con permisos personalizados (solo ver en vivo, o también revisar grabaciones, o administración completa). Para uso familiar o de empresa, esto significa que el dueño, el gerente y el personal de seguridad pueden tener cada uno su propio acceso con el nivel de permisos adecuado. No hay límite rígido de usuarios — en la práctica configuramos hasta 5–8 accesos sin problema.',
      },
      {
        q: '¿Puedo recibir alertas cuando detecten movimiento?',
        a: 'Sí. Las cámaras IP que instalamos tienen detección de movimiento inteligente que distingue entre personas, vehículos y objetos — lo que reduce las falsas alarmas. Cuando se detecta movimiento en una zona configurada, recibes una notificación push con una imagen del evento. Puedes configurar zonas de detección específicas, horarios de activación y sensibilidad de la alerta. La configuración la hacemos nosotros el día de la entrega.',
      },
      {
        q: '¿Qué pasa con las grabaciones si se va la luz o el internet?',
        a: 'Si se va la luz, las cámaras y el NVR se apagan pero todas las grabaciones anteriores quedan intactas en el disco duro. Cuando regresa la energía, el sistema reinicia automáticamente y retoma la grabación. Si se va el internet, el sistema sigue grabando localmente sin interrupciones — solo pierdes el acceso remoto temporal. Para proteger contra cortes de luz en sitios críticos instalamos UPS (no-break) que dan entre 30 y 120 minutos de respaldo.',
      },
    ],
  },
  {
    id: 'cobertura',
    label: 'Cobertura y zonas',
    color: 'rose',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />',
    items: [
      {
        q: '¿En qué zonas instalan cámaras de seguridad?',
        a: 'Cobertura directa en las 16 alcaldías de la Ciudad de México y en más de 16 municipios del Estado de México (Naucalpan, Tlalnepantla, Ecatepec, Nezahualcóyotl, Atizapán, Coacalco, Cuautitlán Izcalli, Huixquilucan, Tultitlán, Chimalhuacán, y más). También operamos en Guadalajara y Monterrey con técnicos certificados locales. Para otros estados hacemos evaluación caso por caso.',
      },
      {
        q: '¿Cobran cargo adicional por desplazamiento o por zonas alejadas?',
        a: 'No. El precio de la instalación es el mismo sin importar si estás en el centro de CDMX o en un municipio periférico del Estado de México. No hay cargo por kilómetro ni por zona. Lo único que varía es el tiempo de respuesta para agendar la visita técnica: zonas céntricas suelen tener disponibilidad en 24–48 horas, zonas periféricas en 48–72 horas.',
      },
      {
        q: '¿Pueden instalar en Guadalajara, Monterrey o fuera de la ZMVM?',
        a: 'Sí. En Guadalajara y Monterrey contamos con coordinadores de proyecto y técnicos certificados locales — el mismo proceso, los mismos estándares y la misma garantía de 2 años que en CDMX. Para el corredor Bajío (Guanajuato, Querétaro, Aguascalientes) atendemos proyectos industriales y corporativos coordinados desde CDMX. Para otras ciudades, contáctanos para evaluar viabilidad.',
      },
      {
        q: '¿Cuánto tiempo tarda en agendarse la primera visita técnica?',
        a: 'En zonas de alta densidad (Benito Juárez, Miguel Hidalgo, Cuauhtémoc, Naucalpan, Tlalnepantla) podemos ir el mismo día si contactas antes del mediodía y hay disponibilidad. En la mayoría de zonas agendamos entre 24 y 48 horas. Para zonas periféricas (Toluca, Metepec, Valle de Chalco) entre 48 y 72 horas. Escríbenos por WhatsApp con tu colonia y te confirmamos disponibilidad en minutos.',
      },
    ],
  },
];

// Todas las preguntas planas para JSON-LD
const allFaqs = categorias.flatMap((c) => c.items);
const phone = SITE.contact.whatsapp;
---

<BaseLayout
  title="Preguntas Frecuentes sobre Cámaras de Seguridad CCTV | Cámara de Seguridad México"
  description="Resuelve todas tus dudas sobre instalación de cámaras CCTV: precios, garantías, marcas, proceso, app y cobertura. 31 respuestas de expertos certificados Hikvision y Dahua."
  canonical={`${SITE.url}/faq/`}
  breadcrumb={breadcrumb}
  faq={allFaqs}
>

  <!-- ── 1. HERO ──────────────────────────────────────────────── -->
  <Hero
    eyebrow="31 PREGUNTAS · 6 CATEGORÍAS · RESPUESTAS REALES"
    preTitle="Resolvemos tus dudas"
    title1="Sin Letra"
    title2="Pequeña"
    subtitle="sobre cámaras, precios, garantías y más."
    descriptionHtml={`Más de <strong class="font-bold text-brand-500">31 preguntas reales</strong>
respondidas por técnicos certificados Hikvision y Dahua — sobre precios, instalación,
garantías, equipos y cobertura. Si no encuentras la tuya,
<strong class="font-bold text-brand-500">respondemos por WhatsApp en menos de 15 minutos</strong>.`}
    col2Eyebrow="Por qué somos diferentes"
    col2Title="Transparencia total, "
    col2TitleHighlight="sin tecnicismos"
    col2Paragraphs={[
      {
        html: `<strong class="font-bold text-brand-500">No hay preguntas incómodas.</strong>
Sobre el precio real, sobre lo que no incluye la garantía, sobre por qué un sistema puede
costar el doble que otro — respondemos todo sin evasivas, porque sabemos que un cliente
informado toma mejores decisiones y genera menos problemas post-instalación.`,
      },
      {
        html: `<strong class="font-bold text-brand-500">Si algo cambió desde que escribimos estas respuestas</strong>,
te lo decimos directamente por WhatsApp en menos de 15 minutos. Los precios, la disponibilidad
de zonas y los modelos de equipo evolucionan — esta página se actualiza mensualmente
pero el chat siempre tiene la respuesta más reciente.`,
      },
    ]}
    showRecBadge={false}
    showQuickLinks={true}
  />

  <!-- ── 2. STATS BAND ───────────────────────────────────────── -->
  <div class="bg-brand-500 py-10 lg:py-12" aria-label="Resumen de contenido">
    <div class="container">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:gap-6">
        {[
          { val: '31',     lbl: 'preguntas respondidas' },
          { val: '6',      lbl: 'categorías temáticas' },
          { val: '< 15m',  lbl: 'respuesta por WhatsApp' },
          { val: '10+',    lbl: 'años de experiencia' },
        ].map((s) => (
          <div class="rounded-xl border border-white/10 bg-white/5 p-5 text-center">
            <p class="font-display text-3xl font-black leading-none text-white sm:text-4xl">{s.val}</p>
            <p class="mt-2 text-[11.5px] font-semibold uppercase tracking-wider text-cream-300">{s.lbl}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── 3. CONTENIDO PRINCIPAL: sidebar + FAQs ─────────────── -->
  <section class="section-cream" id="preguntas">
    <div class="container">

      <div class="grid gap-10 lg:grid-cols-[280px_1fr] lg:gap-14 lg:items-start">

        <!-- ── SIDEBAR STICKY ──────────────────────────────────── -->
        <aside class="lg:sticky lg:top-28 lg:self-start space-y-4">

          <!-- Navegación por categorías -->
