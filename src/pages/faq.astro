<style>
  .faq-item summary::-webkit-details-marker { display: none; }
  .cat-active  { @apply bg-brand-500 text-white shadow-sm; }
  .cat-inactive { @apply bg-white text-ink-700 border border-cream-200 hover:border-brand-500/30 hover:bg-cream-50; }
</style>

<script define:vars={{ phone }}>
  // ── Category tab switching ────────────────────────────────────
  const catBtns   = document.querySelectorAll('.cat-btn');
  const catPanels = document.querySelectorAll('.cat-panel');
  const catIcons  = document.querySelectorAll('.cat-btn span:first-child span');

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.cat;

      catBtns.forEach((b, i) => {
        const isActive = b.dataset.cat === target;
        b.classList.toggle('cat-active', isActive);
        b.classList.toggle('cat-inactive', !isActive);
        // Icon bg
        const icon = b.querySelector('.flex.h-8');
        if (icon) {
          icon.classList.toggle('bg-brand-500', isActive);
          icon.classList.toggle('text-white', isActive);
          icon.classList.toggle('bg-cream-200', !isActive);
          icon.classList.toggle('text-ink-500', !isActive);
        }
      });

      catPanels.forEach((p) => {
        p.classList.toggle('hidden', p.id !== `cat-panel-${target}`);
      });

      // Scroll to panel on mobile
      if (window.innerWidth < 1024) {
        document.getElementById(`cat-panel-${target}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // ── WhatsApp form ─────────────────────────────────────────────
  document.getElementById('faq-send')?.addEventListener('click', () => {
    const nombre   = document.getElementById('faq-nombre').value.trim() || 'un cliente';
    const zona     = document.getElementById('faq-zona').value.trim();
    const servicio = document.getElementById('faq-servicio').value || 'instalación de cámaras';
    const camaras  = document.getElementById('faq-camaras').value;
    const urgencia = document.getElementById('faq-urgencia').value;
    const msg      = document.getElementById('faq-msg').value.trim();

    let texto = `Hola, soy ${nombre}. Me interesa una cotización para ${servicio}`;
    if (camaras && camaras !== 'No sé aún') texto += `, aprox. ${camaras}`;
    if (zona) texto += `, en ${zona}`;
    texto += `.`;
    if (urgencia) texto += ` Tiempo: ${urgencia}.`;
    if (msg) texto += ` ${msg}`;

    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(texto)}`, '_blank');
  });
</script>
