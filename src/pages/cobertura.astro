---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import FaqSection from '@components/FaqSection.astro';
import CTASection from '@components/CTASection.astro';
import RelatedLinks from '@components/RelatedLinks.astro';
import { SITE } from '@/consts';
import { PAGE_SEO } from '@/data/seo';

const seo = PAGE_SEO['/cobertura/'];

const breadcrumb = [
  { name: 'Inicio', url: '/' },
  { name: 'Cobertura', url: '/cobertura/' },
];

interface Zona {
  nombre: string;
  tiempo: string;
  tipo: 'alta' | 'media' | 'normal';
}

const cdmxAlcaldias: Zona[] = [
  { nombre: 'Benito Juárez',        tiempo: '2–4 h',  tipo: 'alta'   },
  { nombre: 'Cuauhtémoc',           tiempo: '2–4 h',  tipo: 'alta'   },
  { nombre: 'Miguel Hidalgo',       tiempo: '2–4 h',  tipo: 'alta'   },
  { nombre: 'Álvaro Obregón',       tiempo: '3–5 h',  tipo: 'alta'   },
  { nombre: 'Coyoacán',             tiempo: '3–5 h',  tipo: 'alta'   },
  { nombre: 'Iztacalco',            tiempo: '3–5 h',  tipo: 'alta'   },
  { nombre: 'Venustiano Carranza',  tiempo: '3–5 h',  tipo: 'alta'   },
  { nombre: 'Azcapotzalco',         tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Cuajimalpa',           tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Gustavo A. Madero',    tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Iztapalapa',           tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Xochimilco',           tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Magdalena Contreras',  tiempo: '6–24 h', tipo: 'normal' },
  { nombre: 'Milpa Alta',           tiempo: '6–24 h', tipo: 'normal' },
  { nombre: 'Tláhuac',              tiempo: '6–24 h', tipo: 'normal' },
  { nombre: 'Tlalpan',              tiempo: '6–24 h', tipo: 'normal' },
];

interface MunicipioEdomex {
  nombre: string;
  tiempo: string;
  tipo: 'alta' | 'media' | 'normal';
}

const edomexMunicipios: MunicipioEdomex[] = [
  { nombre: 'Naucalpan',            tiempo: '2–4 h',  tipo: 'alta'   },
  { nombre: 'Tlalnepantla',         tiempo: '2–4 h',  tipo: 'alta'   },
  { nombre: 'Ecatepec',             tiempo: '3–5 h',  tipo: 'alta'   },
  { nombre: 'Nezahualcóyotl',       tiempo: '3–5 h',  tipo: 'alta'   },
  { nombre: 'Atizapán',             tiempo: '3–5 h',  tipo: 'media'  },
  { nombre: 'Coacalco',             tiempo: '3–5 h',  tipo: 'media'  },
  { nombre: 'Cuautitlán Izcalli',   tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Huixquilucan',         tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Tultitlán',            tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Chimalhuacán',         tiempo: '4–6 h',  tipo: 'media'  },
  { nombre: 'Cuautitlán',           tiempo: '5–8 h',  tipo: 'normal' },
  { nombre: 'Ixtapaluca',           tiempo: '5–8 h',  tipo: 'normal' },
  { nombre: 'Metepec',              tiempo: '6–12 h', tipo: 'normal' },
  { nombre: 'Tecámac',              tiempo: '5–8 h',  tipo: 'normal' },
  { nombre: 'Toluca',               tiempo: '6–12 h', tipo: 'normal' },
  { nombre: 'Valle de Chalco',      tiempo: '5–8 h',  tipo: 'normal' },
];

interface CiudadNacional {
  ciudad: string;
  estado: string;
  modelo: string;
  desc: string;
  icon: string;
}

const ciudadesNacional: CiudadNacional[] = [
  {
    ciudad: 'Guadalajara',
    estado: 'Jalisco',
    modelo: 'Coordinador + técnico local',
    desc: 'Contamos con coordinadores de proyecto y técnicos certificados locales. Mismos estándares de instalación y garantía que CDMX.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />',
  },
  {
    ciudad: 'Monterrey',
    estado: 'Nuevo León',
    modelo: 'Coordinador + técnico local',
    desc: 'Red de técnicos certificados Hikvision y Dahua en la zona metropolitana de Monterrey y municipios aledaños.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />',
  },
  {
    ciudad: 'Bajío',
    estado: 'Guanajuato · Querétaro · Aguascalientes',
    modelo: 'Proyecto coordinado desde CDMX',
    desc: 'Para plantas industriales y proyectos corporativos en el corredor Bajío. Incluye visita de diagnóstico y supervisión remota durante la instalación.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />',
  },
  {
    ciudad: 'Resto del país',
    estado: 'Proyecto especial',
    modelo: 'Cotización caso por caso',
    desc: 'Para proyectos en otras ciudades evaluamos la viabilidad, tiempos y costos de desplazamiento. Contáctanos para un diagnóstico inicial sin costo.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M20.893 13.393l-1.135-1.135a2.252 2.252 0 0 1-.421-.585l-1.08-2.16a.414.414 0 0 0-.663-.107.827.827 0 0 1-.812.21l-1.273-.363a.89.89 0 0 0-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 0 1-1.81 1.025 1.055 1.055 0 0 1-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 0 1-1.383-2.46l.007-.042a2.25 2.25 0 0 1 .29-.787l.09-.15a2.25 2.25 0 0 1 2.37-1.048l1.178.236a1.125 1.125 0 0 0 1.302-.795l.208-.73a1.125 1.125 0 0 0-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 0 1-1.591.659h-.18c-.249 0-.487.1-.662.274a.931.931 0 0 1-1.458-1.137l1.411-2.353a2.25 2.25 0 0 0 .286-.76m11.928 9.869A9 9 0 0 0 8.965 3.525m11.928 9.868A9 9 0 1 1 8.965 3.525" />',
  },
];

// Places schema — todas las zonas cubiertas
const places = [
  ...cdmxAlcaldias.map((z) => ({
    name: z.nombre,
    type: 'AdministrativeArea' as const,
    containedInPlace: 'Ciudad de México',
  })),
  ...edomexMunicipios.map((z) => ({
    name: z.nombre,
    type: 'AdministrativeArea' as const,
    containedInPlace: 'Estado de México',
  })),
  ...ciudadesNacional.map((c) => ({
    name: c.ciudad,
    type: 'City' as const,
    containedInPlace: c.estado,
  })),
];

const faq = [
  {
    q: '¿La visita técnica realmente es gratuita en toda la ZMVM?',
    a: 'Sí, sin excepción. No cobramos costo de desplazamiento en ninguna de las 16 alcaldías de CDMX ni en los municipios del Estado de México listados en esta página. La visita técnica incluye levantamiento físico, plano de cobertura y propuesta formal — todo sin costo y sin compromiso de compra.',
  },
  {
    q: '¿En cuánto tiempo pueden venir a hacer la visita técnica?',
    a: 'Generalmente agendamos la visita técnica entre 24 y 48 horas después del primer contacto. Para zonas de alta densidad (Benito Juárez, Miguel Hidalgo, Cuauhtémoc, Naucalpan, Tlalnepantla) podemos ir el mismo día si hay disponibilidad. El tiempo en la tabla es el tiempo de respuesta inicial — la visita se agenda por cita.',
  },
  {
    q: '¿Pueden instalar en Guadalajara o Monterrey?',
    a: 'Sí. Contamos con coordinadores de proyecto y técnicos certificados locales en Guadalajara y Monterrey. El proceso es idéntico al de CDMX: visita técnica, propuesta formal, instalación certificada y garantía de 2 años por escrito. Contáctanos para agendar la visita inicial.',
  },
  {
    q: '¿Qué pasa si mi colonia no está en la lista?',
    a: 'La lista muestra los municipios y alcaldías principales pero no es exhaustiva. Si tu ubicación está dentro de la ZMVM o en zona metropolitana de las ciudades mencionadas, casi con certeza podemos atenderte. Escríbenos por WhatsApp con tu colonia y te confirmamos disponibilidad en minutos.',
  },
  {
    q: '¿Los tiempos de respuesta son garantizados?',
    a: 'Los tiempos indicados son estimados habituales en días hábiles con cita previa. No son tiempos de emergencia — son el tiempo típico para agendar una primera visita técnica. En casos urgentes (como reparaciones post-robo) priorizamos la atención y solemos tener disponibilidad el mismo día o siguiente.',
  },
  {
    q: '¿Cobran más por zonas alejadas del centro?',
    a: 'No cobramos cargo adicional por desplazamiento dentro de la ZMVM. El precio de la instalación es el mismo sin importar si estás en el centro o en un municipio periférico. Lo único que varía es el tiempo de respuesta para agendar la visita.',
  },
  {
    q: '¿Hacen instalaciones en fraccionamientos con caseta de acceso?',
    a: 'Sí, es muy común. Solo necesitamos que registres al técnico como visitante antes de la visita. En instalaciones residenciales de lujo con protocolos de seguridad estrictos, coordinamos todo previamente y el técnico llega con identificación y vehículo identificado.',
  },
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical="/cobertura/"
  breadcrumb={breadcrumb}
  faq={faq}
  places={places}
>

  <!-- ── 1. HERO ──────────────────────────────────────────────── -->
  <Hero
    eyebrow="COBERTURA · CDMX · EDOMEX · NACIONAL"
    preTitle="Llegamos a donde"
    title1="Tú nos"
    title2="Necesitas"
    subtitle="16 alcaldías, 16+ municipios y presencia nacional."
    descriptionHtml={`Cobertura directa en toda la
<strong class="font-bold text-brand-500">Zona Metropolitana del Valle de México</strong>
— sin cargo por desplazamiento, sin excepciones. Visita técnica gratuita agendada en
<strong class="font-bold text-brand-500">24 a 48 horas</strong>.
También operamos en Guadalajara, Monterrey y el corredor Bajío.`}
    col2Eyebrow="Nuestro alcance"
    col2Title="Misma garantía "
    col2TitleHighlight="en toda la zona"
    col2Paragraphs={[
      {
        html: `<strong class="font-bold text-brand-500">No importa si estás en Benito Juárez o en Ixtapaluca</strong>
— el precio de la instalación es el mismo. No cobramos cargo por desplazamiento, no cobramos
por la visita técnica y no reducimos la calidad del trabajo según la distancia. Cada proyecto
sigue el mismo proceso de 6 pasos.`,
      },
      {
        html: `<strong class="font-bold text-brand-500">Para proyectos fuera de la ZMVM</strong>
operamos con coordinadores de proyecto y técnicos certificados locales en Guadalajara y
Monterrey. En el Bajío atendemos proyectos industriales y corporativos coordinados desde CDMX
con supervisión directa.`,
      },
    ]}
    showRecBadge={true}
    showQuickLinks={true}
  />

  <!-- ── 2. ZONAS — tabs CDMX / Edomex / Nacional ────────────── -->
  <section class="section-cream" id="zonas">
    <div class="container">

      <div class="grid items-end gap-8 lg:grid-cols-[1fr_2fr] lg:gap-16">
        <div>
          <span class="eyebrow">Zonas de cobertura</span>
          <h2 class="heading-lg mt-4 text-balance">
            Dónde instalamos
            <span class="text-accent-500">y en cuánto tiempo</span>
          </h2>
          <span class="marker-line mt-5"></span>
        </div>
        <div class="space-y-4">
          <p class="lead">
            Cada alcaldía y municipio tiene un tiempo estimado de primera respuesta para agendar
            la visita técnica. Las zonas en verde tienen disponibilidad el mismo día o siguiente.
            Las amarillas y grises se agendan en 24–72 horas.
          </p>
          <p class="text-[15.5px] leading-relaxed text-ink-600">
            Todos los tiempos son en días hábiles con cita previa. Si tienes urgencia (post-robo
            o falla de sistema existente) escríbenos directamente — solemos tener disponibilidad
            prioritaria el mismo día.
          </p>
        </div>
      </div>

      <!-- Leyenda de colores -->
      <div class="mt-10 flex flex-wrap gap-4">
        <span class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-4 py-1.5 text-[12.5px] font-semibold text-emerald-700">
          <span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
          Alta prioridad · 2–5 h
        </span>
        <span class="inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-4 py-1.5 text-[12.5px] font-semibold text-amber-700">
          <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
          Prioridad media · 3–8 h
        </span>
        <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-4 py-1.5 text-[12.5px] font-semibold text-slate-600">
          <span class="h-2.5 w-2.5 rounded-full bg-slate-400"></span>
          Zona periférica · 6–24 h
        </span>
      </div>

      <!-- Tabs -->
      <div class="mt-8" id="zona-tabs">

        <!-- Tab buttons -->
        <div class="flex gap-0 overflow-hidden rounded-xl border border-cream-200 bg-white w-fit">
          <button data-tab="cdmx"   class="tab-btn tab-active  px-6 py-3 text-[13.5px] font-bold transition-colors">Ciudad de México</button>
          <button data-tab="edomex" class="tab-btn tab-inactive px-6 py-3 text-[13.5px] font-bold transition-colors border-l border-cream-200">Estado de México</button>
        </div>

        <!-- CDMX panel -->
        <div id="panel-cdmx" class="tab-panel mt-6">
          <div class="overflow-hidden rounded-2xl border border-cream-200 bg-white shadow-sm">
            <div class="flex items-center gap-4 bg-brand-500 px-6 py-4">
              <span class="font-display text-3xl font-black text-accent-400">16</span>
              <div>
                <p class="text-[10.5px] font-bold uppercase tracking-[0.22em] text-cream-200">Alcaldías cubiertas</p>
                <p class="font-display text-lg font-black text-white">Ciudad de México</p>
              </div>
              <span class="ml-auto rounded-full bg-white/10 px-3 py-1 text-[11px] font-semibold text-cream-200">Cobertura directa · sin cargo extra</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
              {cdmxAlcaldias.map((z, i) => {
                const colorDot   = z.tipo === 'alta' ? 'bg-emerald-500' : z.tipo === 'media' ? 'bg-amber-400' : 'bg-slate-400';
                const colorBadge = z.tipo === 'alta' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : z.tipo === 'media' ? 'bg-amber-50 text-amber-700 border-amber-200' : 'bg-slate-50 text-slate-500 border-slate-200';
                const borderR = (i + 1) % 4 !== 0 ? 'lg:border-r' : '';
                const borderB = i < cdmxAlcaldias.length - 4 ? 'border-b' : '';
                return (
                  <div class={`flex items-center justify-between gap-3 px-5 py-3.5 border-cream-100 ${borderR} ${borderB}`}>
                    <div class="flex items-center gap-2.5 min-w-0">
                      <span class={`h-2 w-2 shrink-0 rounded-full ${colorDot}`}></span>
                      <span class="truncate text-[13.5px] font-medium text-ink-700">{z.nombre}</span>
                    </div>
                    <span class={`shrink-0 rounded-full border px-2 py-0.5 text-[11px] font-semibold ${colorBadge}`}>{z.tiempo}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <!-- Edomex panel -->
        <div id="panel-edomex" class="tab-panel mt-6 hidden">
          <div class="overflow-hidden rounded-2xl border border-cream-200 bg-white shadow-sm">
            <div class="flex items-center gap-4 bg-accent-600 px-6 py-4">
              <span class="font-display text-3xl font-black text-white">16+</span>
              <div>
                <p class="text-[10.5px] font-bold uppercase tracking-[0.22em] text-white/70">Municipios cubiertos</p>
                <p class="font-display text-lg font-black text-white">Estado de México</p>
              </div>
              <span class="ml-auto rounded-full bg-white/15 px-3 py-1 text-[11px] font-semibold text-white/85">Cobertura directa · sin cargo extra</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
              {edomexMunicipios.map((z, i) => {
                const colorDot   = z.tipo === 'alta' ? 'bg-emerald-500' : z.tipo === 'media' ? 'bg-amber-400' : 'bg-slate-400';
                const colorBadge = z.tipo === 'alta' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : z.tipo === 'media' ? 'bg-amber-50 text-amber-700 border-amber-200' : 'bg-slate-50 text-slate-500 border-slate-200';
                const borderR = (i + 1) % 4 !== 0 ? 'lg:border-r' : '';
                const borderB = i < edomexMunicipios.length - 4 ? 'border-b' : '';
                return (
                  <div class={`flex items-center justify-between gap-3 px-5 py-3.5 border-cream-100 ${borderR} ${borderB}`}>
                    <div class="flex items-center gap-2.5 min-w-0">
                      <span class={`h-2 w-2 shrink-0 rounded-full ${colorDot}`}></span>
                      <span class="truncate text-[13.5px] font-medium text-ink-700">{z.nombre}</span>
                    </div>
                    <span class={`shrink-0 rounded-full border px-2 py-0.5 text-[11px] font-semibold ${colorBadge}`}>{z.tiempo}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

      </div>

      <!-- CTA inline -->
      <div class="mt-8 flex flex-col items-start gap-3 rounded-2xl border-2 border-brand-500/20 bg-white p-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-display text-[16px] font-black text-brand-500">¿Tu colonia no aparece?</p>
          <p class="mt-1 text-[13.5px] text-ink-600">Escríbenos con tu ubicación y te confirmamos disponibilidad en minutos.</p>
        </div>
        <a
          href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent('Hola, quiero verificar si tienen cobertura en mi zona.')}`}
          target="_blank"
          rel="noopener"
          class="shrink-0 btn-primary"
        >
          Verificar mi zona
        </a>
      </div>
    </div>
  </section>

  <!-- ── 3. STATS BAND ───────────────────────────────────────── -->
  <section class="bg-brand-500 py-12 lg:py-14" aria-label="Cifras de cobertura">
    <div class="container">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:gap-6">
        {[
          { val: '32+',    lbl: 'zonas de cobertura directa' },
          { val: '24–48h', lbl: 'para agendar visita técnica' },
          { val: '$0',     lbl: 'costo de desplazamiento' },
          { val: '100%',   lbl: 'mismo precio en toda la zona' },
        ].map((s) => (
          <div class="rounded-xl border border-white/10 bg-white/5 p-5 text-center">
            <p class="font-display text-3xl font-black leading-none text-white sm:text-4xl">{s.val}</p>
            <p class="mt-2 text-[11.5px] font-semibold uppercase tracking-wider text-cream-300">{s.lbl}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 4. QUÉ INCLUYE LA VISITA TÉCNICA ────────────────────── -->
  <section class="section-white" id="visita-tecnica">
    <div class="container">

      <div class="grid items-end gap-8 lg:grid-cols-[1fr_2fr] lg:gap-16">
        <div>
          <span class="eyebrow">Visita técnica gratuita</span>
          <h2 class="heading-lg mt-4 text-balance">
            Lo que hacemos
            <span class="text-accent-500">cuando llegamos</span>
          </h2>
          <span class="marker-line mt-5"></span>
        </div>
        <div class="space-y-4">
          <p class="lead">
            La visita técnica no es una visita de ventas. Es un trabajo real de diagnóstico que
            toma entre 45 minutos y 2 horas según el tamaño del espacio. Te entregamos resultados
            concretos antes de pedir cualquier decisión.
          </p>
          <p class="text-[15.5px] leading-relaxed text-ink-600">
            Muchos de nuestros clientes nos contratan precisamente porque en la visita encontramos
            problemas de cobertura que el instalador anterior no detectó. No vendemos cámaras —
            diseñamos sistemas que funcionan.
          </p>
        </div>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            n: '01',
            titulo: 'Levantamiento físico',
            desc: 'Recorremos todo el espacio: accesos, perímetros, áreas internas, pasillos y zonas de alto riesgo. Identificamos puntos ciegos y ángulos críticos.',
