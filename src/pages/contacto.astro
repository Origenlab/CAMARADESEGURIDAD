  function checkAvailability() {
    const now  = new Date();
    const day  = now.getDay();   // 0=Dom, 1=Lun…6=Sab
    const hour = now.getHours();
    const dot  = document.getElementById('avail-dot');
    const text = document.getElementById('avail-text');
    if (!dot || !text) return;

    const isWeekday = day >= 1 && day <= 5;
    const isSaturday = day === 6;
    const inHours = (isWeekday && hour >= 9 && hour < 19) || (isSaturday && hour >= 9 && hour < 15);

    if (inHours) {
      dot.className  = 'h-3 w-3 rounded-full bg-emerald-400 shadow-[0_0_8px_#34d399]';
      text.textContent = '✓ Estamos disponibles ahora — respondemos en menos de 15 minutos';
      text.className = 'font-display text-[14px] font-bold text-emerald-400';
    } else {
      const nextDay = isSaturday ? 'el lunes' : day === 0 ? 'mañana (lunes)' : 'mañana';
      dot.className  = 'h-3 w-3 rounded-full bg-amber-400';
      text.textContent = `Fuera de horario — respondemos ${nextDay} a las 9:00 AM. Para urgencias escríbenos igual.`;
      text.className = 'font-display text-[14px] font-bold text-amber-300';
    }
  }
  checkAvailability();

  // ── Character counter ─────────────────────────────────────────
  const msgField   = document.getElementById('ct-msg');
  const msgCounter = document.getElementById('ct-counter');
  if (msgField && msgCounter) {
    msgField.addEventListener('input', () => {
      const len = msgField.value.length;
      msgCounter.textContent = `${len} / 300`;
      msgCounter.className = len > 250 ? 'text-[11px] text-amber-500 font-semibold' : 'text-[11px] text-ink-300';
    });
  }

  // ── WhatsApp form submit ──────────────────────────────────────
  document.getElementById('ct-send')?.addEventListener('click', () => {
    const nombre     = document.getElementById('ct-nombre').value.trim() || 'un cliente';
    const empresa    = document.getElementById('ct-empresa').value.trim();
    const tipo       = document.getElementById('ct-tipo').value || 'instalación de cámaras';
    const camaras    = document.getElementById('ct-camaras').value;
    const presupuesto = document.getElementById('ct-presupuesto').value;
    const colonia    = document.getElementById('ct-colonia').value.trim();
    const alcaldia   = document.getElementById('ct-alcaldia').value.trim();
    const urgencia   = document.getElementById('ct-urgencia').value;
    const msg        = document.getElementById('ct-msg').value.trim();

    let texto = `Hola, soy ${nombre}`;
    if (empresa) texto += ` de ${empresa}`;
    texto += `. Solicito cotización para ${tipo}`;
    if (camaras && camaras !== 'No lo sé aún') texto += `, ${camaras}`;
    if (colonia) texto += `, en ${colonia}`;
    if (alcaldia) texto += `, ${alcaldia}`;
    texto += '.';
    if (presupuesto && presupuesto !== 'No definido') texto += ` Presupuesto aprox: ${presupuesto}.`;
    if (urgencia) texto += ` Tiempo: ${urgencia}.`;
    if (msg) texto += ` ${msg}`;

    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(texto)}`, '_blank');
  });
</script>
