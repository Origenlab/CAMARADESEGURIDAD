---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import CTASection from '@components/CTASection.astro';
import RelatedLinks from '@components/RelatedLinks.astro';
import { SITE } from '@/consts';

export async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map((s) => ({
    params: { slug: s.id.replace(/\.md$/, '') },
    props: { servicio: s },
  }));
}

const { servicio } = Astro.props;
const { data: s } = servicio;
const slug = servicio.id.replace(/\.md$/, '');

const isBrand   = s.color === 'brand';
const accentHex = isBrand ? '#0A2540' : '#DC2626';

const breadcrumb = [
  { name: 'Inicio',    url: '/' },
  { name: 'Servicios', url: '/servicios/' },
  { name: s.shortTitle ?? s.title, url: `/servicios/${slug}/` },
];

const faqSchema = s.faq.map((f) => ({ q: f.q, a: f.a }));

// Products schema para los paquetes de ESTE servicio
const productsSchema = (s.paquetes ?? [])
  .map((pkg) => ({
    name: `${pkg.name} — ${s.title}`,
    description: pkg.detail,
    ...(pkg.precio !== undefined && { price: pkg.precio }),
    priceCurrency: 'MXN',
    brand: 'Cámara de Seguridad',
    category: s.title,
    url: `/servicios/${slug}/#paquetes`,
  }))
  .filter((p) => p.price !== undefined);

// Service schema para esta página
const serviceSchema = [
  {
    name: s.title,
    description: s.description,
    url: `/servicios/${slug}/`,
    serviceType: s.title,
  },
];

// SEO meta optimizado por slug
const seoTitle = s.seo?.title ?? `${s.title} | Instalación CCTV Profesional · Garantía 2 Años`;
const seoDesc = s.seo?.description ?? `${s.description} Visita técnica gratuita en CDMX y Edomex. Técnicos certificados Hikvision y Dahua, garantía 2 años por escrito.`;
const seoKeywords = `${s.title.toLowerCase()}, cámaras de seguridad ${slug}, instalación CCTV ${slug}, ${s.shortTitle?.toLowerCase() ?? ''}, Hikvision, Dahua, cotización gratis`;

// ── Iconos SVG paths ───────────────────────────────────────────
const svgIcons: Record<string, string> = {
  home:        '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  store:       '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/><path d="M9 13a3 3 0 1 0 6 0"/>',
  factory:     '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/><path d="M7 17h2M11 17h2M15 17h2"/>',
  lock:        '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
  camera:      '<path d="M3 8a2 2 0 0 1 2-2h3l2-2h4l2 2h3a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z"/><circle cx="12" cy="13" r="4"/>',
  shield:      '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>',
  eye:         '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>',
  bell:        '<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>',
  wifi:        '<path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
  monitor:     '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>',
  car:         '<path d="M5 13l2-5h10l2 5"/><path d="M5 13v5h2v-2h10v2h2v-5z"/><circle cx="8" cy="16" r="1.5"/><circle cx="16" cy="16" r="1.5"/>',
  fingerprint: '<path d="M2 12C2 6.5 6.5 2 12 2a10 10 0 0 1 8 4"/><path d="M5 19.5C5.5 18 6 15 6 12c0-3.3 2.7-6 6-6 1.8 0 3.4.8 4.5 2"/><path d="M8 19a23 23 0 0 0 .5-5"/><path d="M12 19v-3.5c0-1.7 1.3-3 3-3"/><path d="M18 19c-.3-1-.5-2-.5-3.5"/><path d="M20 19c-.3-2.5-1.5-5-3-6.5"/>',
  tool:        '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  ptz:         '<circle cx="12" cy="12" r="9"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/><circle cx="12" cy="12" r="3"/>',
  thermal:     '<path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4 4 0 1 0 5 0Z"/>',
  lpr:         '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 2v5M8 2v5M2 12h20"/>',
};

// ── Color classes ──────────────────────────────────────────────
const headerBg   = isBrand ? 'bg-brand-500' : 'bg-accent-500';
const headerBg2  = isBrand ? 'bg-brand-600' : 'bg-accent-600';
const eyebrowCol = isBrand ? 'text-accent-400' : 'text-white/70';
const markerCol  = isBrand ? 'bg-accent-500'  : 'bg-white/50';
const badgeBg    = isBrand ? 'bg-brand-500 text-white' : 'bg-accent-500 text-white';
const btnPrimCol = isBrand ? 'btn-brand' : 'btn-primary';
const iconBg     = isBrand ? 'bg-brand-50 text-brand-500 group-hover/sub:bg-brand-500 group-hover/sub:text-white'
                           : 'bg-accent-50 text-accent-500 group-hover/sub:bg-accent-500 group-hover/sub:text-white';

// Formateo de precio MXN
const formatPrice = (n: number) =>
  new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', maximumFractionDigits: 0 }).format(n);
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  keywords={seoKeywords}
  canonical={`/servicios/${slug}/`}
  breadcrumb={breadcrumb}
  faq={faqSchema}
  services={serviceSchema}
  products={productsSchema}
>

  <!-- ══════════════════════════════════════════════════════
       1. HERO — banner de color sólido con título + subtítulo
       ══════════════════════════════════════════════════════ -->
  <section class={`relative overflow-hidden ${headerBg}`} aria-labelledby="hero-title">

    <!-- Círculos decorativos de fondo -->
    <div class="pointer-events-none absolute -right-24 -top-24 h-96 w-96 rounded-full bg-white/5" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-16 left-1/3 h-64 w-64 rounded-full bg-white/5" aria-hidden="true"></div>
    <div class="pointer-events-none absolute right-1/4 top-1/2 h-32 w-32 rounded-full bg-white/[0.03]" aria-hidden="true"></div>

    <div class="container relative py-14 lg:py-20">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex flex-wrap items-center gap-2 text-[13px]">
          {breadcrumb.map((item, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 text-white/30" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              )}
              {i === breadcrumb.length - 1 ? (
                <span class="font-semibold text-white/90" aria-current="page">{item.name}</span>
              ) : (
                <a href={item.url} class="text-white/60 transition-colors hover:text-white">{item.name}</a>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <!-- Grid hero: texto izq + aside der -->
      <div class="grid gap-10 lg:grid-cols-[1.6fr_1fr] lg:gap-16">

        <!-- Texto principal -->
        <div>
          <span class={`inline-flex items-center gap-2.5 text-[11px] font-bold uppercase tracking-[0.26em] ${eyebrowCol}`}>
            <span class={`h-1.5 w-1.5 rounded-full ${isBrand ? 'bg-accent-500' : 'bg-white/60'}`}></span>
            {s.eyebrow}
          </span>

          <h1 id="hero-title" class="mt-5 font-display text-4xl font-black leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
            {s.title}
          </h1>

          <span class={`mt-5 block h-[3px] w-14 rounded-full ${markerCol}`}></span>

          <p class="mt-6 max-w-2xl text-[16.5px] leading-relaxed text-white/80">
            {s.subtitle}
          </p>

          <!-- CTAs hero -->
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, me interesa el servicio: ${s.title}`)}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3.5 text-[15px] font-bold transition-all hover:-translate-y-0.5 hover:shadow-lg"
              style={`color: ${accentHex}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
              Cotiza gratis
            </a>
            <a
              href="#paquetes"
              class="inline-flex items-center gap-2 rounded-xl border-2 border-white/30 px-6 py-3.5 text-[15px] font-bold text-white transition-all hover:border-white/70 hover:bg-white/10"
            >
              Ver paquetes
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </a>
          </div>
        </div>

        <!-- Aside: stat cards -->
        <div class="grid grid-cols-2 gap-3">
          {s.stats.map((st) => (
            <div class="rounded-2xl border border-white/10 bg-white/8 p-5 backdrop-blur-sm">
              <p class="font-display text-2xl font-black leading-none text-white lg:text-3xl">{st.value}</p>
              <p class="mt-2 text-[11px] font-bold uppercase tracking-[0.18em] text-white/60">{st.label}</p>
            </div>
          ))}
        </div>

      </div>
    </div>

    <!-- Franja inferior decorativa -->
    <div class={`h-1 w-full ${isBrand ? 'bg-accent-500' : 'bg-white/20'}`}></div>
  </section>


  <!-- ══════════════════════════════════════════════════════
       2. DESCRIPCIÓN + PILAR INTRO
       ══════════════════════════════════════════════════════ -->
  <section class="section-white">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-[1fr_420px] lg:gap-20">

        <!-- Descripción larga -->
        <div>
          <span class="eyebrow">Sobre este servicio</span>
          <h2 class="heading-md mt-4 text-balance">
            {s.title} <span class="text-accent-500">en detalle</span>
          </h2>
          <span class="marker-line mt-5"></span>
          <p class="mt-6 text-[16px] leading-[1.8] text-ink-700">
            {s.descripcionLarga ?? s.description}
          </p>

          <!-- Ideal para -->
          {s.idealPara.length > 0 && (
            <div class="mt-8">
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-ink-400">Ideal para</p>
              <ul class="mt-4 flex flex-wrap gap-2">
                {s.idealPara.map((item) => (
                  <li class="rounded-full border border-cream-300 bg-cream-100 px-3.5 py-1.5 text-[13px] font-semibold text-ink-700">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Pilar intro — tarjeta aside -->
        {s.pilarIntro && (
          <aside>
            <div class={`rounded-2xl ${headerBg} p-8 lg:p-10`}>
              <!-- Icono -->
              <span class="grid h-12 w-12 place-items-center rounded-xl bg-white/15">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white" aria-hidden="true" set:html={svgIcons[s.icon] ?? ''}/>
              </span>
              <p class={`mt-4 text-[10px] font-bold uppercase tracking-[0.22em] ${eyebrowCol}`}>
                Por qué elegirnos
              </p>
              <p class="mt-3 text-[15px] leading-[1.75] text-white/85">
                {s.pilarIntro}
              </p>
              <!-- Features incluidas -->
              {s.features.length > 0 && (
                <ul class="mt-6 space-y-2.5">
                  {s.features.map((f) => (
                    <li class="flex items-start gap-2.5 text-[13.5px] text-white/80">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`mt-0.5 h-4 w-4 shrink-0 ${isBrand ? 'text-accent-400' : 'text-white/60'}`} aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                      {f}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </aside>
        )}

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════
       3. SUB-SERVICIOS
       ══════════════════════════════════════════════════════ -->
  {s.subServicios.length > 0 && (
    <section class="section-cream" id="sub-servicios">
      <div class="container">

        <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="eyebrow">Especialidades incluidas</span>
            <h2 class="heading-md mt-4 text-balance">
              Cuatro especialidades,<br/>
              <span class="text-accent-500">una sola garantía</span>.
            </h2>
            <span class="marker-line mt-5"></span>
          </div>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, quiero info sobre ${s.title}`)}`} target="_blank" rel="noopener" class="btn-outline shrink-0">
            Asesoría gratis
          </a>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {s.subServicios.map((sub) => (
            <article class="card group/sub flex flex-col transition-all duration-200 hover:-translate-y-1 hover:shadow-card">

              <!-- Header con icono -->
              <div class={`${headerBg} relative overflow-hidden px-6 py-6`}>
                <div class="pointer-events-none absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/8" aria-hidden="true"></div>
                <span class="relative grid h-11 w-11 place-items-center rounded-xl bg-white/15">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-white" aria-hidden="true" set:html={svgIcons[sub.icon ?? 'camera'] ?? ''}/>
                </span>
                <h3 class="relative mt-4 font-display text-[17px] font-black leading-snug text-white">
                  {sub.name}
                </h3>
              </div>

              <!-- Body -->
              <div class="flex flex-1 flex-col p-6">
                <p class="flex-1 text-[14px] leading-relaxed text-ink-600">
                  {sub.description}
                </p>
                <a
                  href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, quiero info sobre: ${sub.name}`)}`}
                  target="_blank"
                  rel="noopener"
                  class="mt-5 flex items-center gap-2 text-[13px] font-bold text-accent-500 transition-all hover:gap-3"
                >
                  Cotizar este servicio
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 shrink-0" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>
  )}


  <!-- ══════════════════════════════════════════════════════
       4. PAQUETES — PRICING
       ══════════════════════════════════════════════════════ -->
  {s.paquetes.length > 0 && (
    <section class="section-white" id="paquetes">
      <div class="container">

        <div class="grid items-end gap-8 lg:grid-cols-[1fr_2fr]">
          <div>
            <span class="eyebrow">Paquetes y precios</span>
            <h2 class="heading-md mt-4 text-balance">
              Precio justo,<br/>
              <span class="text-accent-500">todo incluido</span>.
            </h2>
            <span class="marker-line mt-5"></span>
          </div>
          <p class="lead text-ink-600">
            Cada paquete incluye equipo, mano de obra, cableado oculto, configuración de app y garantía de
            2 años por escrito. Los precios son punto de partida — la cotización final es personalizada y gratuita.
          </p>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {s.paquetes.map((pkg) => {
            const isPopular = pkg.popular === true;
            const cardBg    = isPopular ? (isBrand ? 'bg-brand-500' : 'bg-accent-500') : 'bg-white';
            const nameCls   = isPopular ? 'text-white' : 'text-brand-500';
            const detailCls = isPopular ? 'text-white/75' : 'text-ink-500';
            const priceCls  = isPopular ? 'text-white' : 'text-brand-500';
            const borderCls = isPopular ? 'border-transparent shadow-[0_8px_32px_rgba(10,37,64,0.3)]' : 'border-cream-200';
            return (
              <article class={`card relative flex flex-col overflow-visible border ${borderCls} ${cardBg}`}>

                {/* Badge popular */}
                {isPopular && (
                  <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                    <span class="rounded-full bg-accent-500 px-4 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-white shadow-cta">
                      Más elegido
                    </span>
                  </div>
                )}

                <div class={`flex flex-1 flex-col p-6 ${isPopular ? 'pt-8' : ''}`}>

                  {/* Nombre paquete */}
                  <h3 class={`font-display text-[17px] font-black leading-snug ${nameCls}`}>
                    {pkg.name}
                  </h3>

                  {/* Precio */}
                  {pkg.precio ? (
                    <div class="mt-4">
                      <span class={`text-[11px] font-bold uppercase tracking-wider ${isPopular ? 'text-white/60' : 'text-ink-400'}`}>desde</span>
                      <p class={`font-display text-3xl font-black leading-none ${priceCls}`}>
                        {formatPrice(pkg.precio)}
                      </p>
                      <span class={`text-[11px] ${isPopular ? 'text-white/50' : 'text-ink-400'}`}>MXN · todo incluido</span>
                    </div>
                  ) : (
                    <div class="mt-4">
                      <p class={`font-display text-xl font-black ${priceCls}`}>
                        Cotización personalizada
                      </p>
                    </div>
                  )}

                  {/* Separador */}
                  <div class={`my-5 h-px w-full ${isPopular ? 'bg-white/15' : 'bg-cream-200'}`}></div>

                  {/* Detalle */}
                  <p class={`flex-1 text-[13.5px] leading-relaxed ${detailCls}`}>
                    {pkg.detail}
                  </p>

                  {/* CTA */}
                  <a
                    href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, me interesa el paquete "${pkg.name}" de ${s.title}.`)}`}
                    target="_blank"
                    rel="noopener"
                    class={`mt-6 flex items-center justify-center gap-2 rounded-xl py-3 text-[14px] font-bold transition-all ${
                      isPopular
                        ? 'bg-white text-brand-500 hover:bg-cream-50 hover:shadow-md'
                        : `border-2 ${isBrand ? 'border-brand-500 text-brand-500 hover:bg-brand-500 hover:text-white' : 'border-accent-500 text-accent-500 hover:bg-accent-500 hover:text-white'}`
                    }`}
                  >
                    Cotizar paquete
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>

        <!-- Nota inferior -->
        <p class="mt-6 text-center text-[13px] text-ink-400">
          ¿Necesitas algo diferente?
          <a href={`https://wa.me/${SITE.contact.whatsapp}`} target="_blank" rel="noopener" class="font-semibold text-accent-500 hover:underline">Cuéntanos tu caso</a>
          y te damos una propuesta a la medida.
        </p>

      </div>
    </section>
  )}


  <!-- ══════════════════════════════════════════════════════
       5. BANNER GARANTÍA
       ══════════════════════════════════════════════════════ -->
  <section class={`${headerBg2} py-12 lg:py-16`} aria-label="Garantía">
    <div class="container">
      <div class="grid gap-8 sm:grid-cols-3 lg:grid-cols-4">

        {[
          { icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>', title: 'Garantía 2 años', sub: 'Equipo + mano de obra por escrito' },
          { icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>', title: 'WhatsApp en 15 min', sub: 'Respuesta rápida sin call center' },
          { icon: '<path d="M3 11l9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>', title: 'Visita técnica gratis', sub: 'En CDMX y Edomex sin costo' },
          { icon: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 2v5M8 2v5M2 12h20"/>', title: 'Instalación en 1–2 días', sub: 'Sin afectar tu operación' },
        ].map((item) => (
          <div class="flex items-start gap-4">
            <span class={`mt-0.5 grid h-10 w-10 shrink-0 place-items-center rounded-xl ${isBrand ? 'bg-accent-500' : 'bg-white/20'}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-white" aria-hidden="true" set:html={item.icon}/>
            </span>
            <div>
              <p class="font-bold text-white">{item.title}</p>
              <p class="mt-0.5 text-[13px] text-white/65">{item.sub}</p>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════
       6. FAQ ESPECÍFICO DEL SERVICIO
       ══════════════════════════════════════════════════════ -->
  {s.faq.length > 0 && (
    <section class="section-cream" id="faq">
      <div class="container">
        <div class="grid gap-12 lg:grid-cols-[1fr_1.8fr]">

          <!-- Texto izquierdo -->
          <div class="lg:sticky lg:top-32 lg:self-start">
            <span class="eyebrow">Preguntas frecuentes</span>
            <h2 class="heading-md mt-4 text-balance">
              Todo lo que necesitas
              <span class="text-accent-500"> saber</span>.
            </h2>
            <span class="marker-line mt-5"></span>
            <p class="mt-5 text-[15px] leading-relaxed text-ink-600">
              Si tu pregunta no está aquí, escríbenos por WhatsApp — respondemos en menos de 15 minutos.
            </p>
            <a
              href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, tengo una pregunta sobre ${s.title}`)}`}
              target="_blank"
              rel="noopener"
              class="mt-6 inline-flex items-center gap-2 text-[14px] font-bold text-accent-500 transition-all hover:gap-3"
            >
              Pregunta por WhatsApp
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>

          <!-- Acordeón FAQ -->
          <div class="space-y-3" id="faq-list">
            {s.faq.map((item, i) => (
              <details class="faq-item group rounded-2xl border border-cream-200 bg-white open:shadow-soft">
                <summary class="flex cursor-pointer select-none list-none items-start justify-between gap-4 p-6 text-[15px] font-bold text-ink-800 transition-colors hover:text-brand-500">
                  <span class="flex items-start gap-3">
                    <span class={`mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full text-[11px] font-black text-white ${isBrand ? 'bg-brand-500' : 'bg-accent-500'}`}>
                      {i + 1}
                    </span>
                    {item.q}
                  </span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 shrink-0 text-ink-400 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </summary>
                <div class="border-t border-cream-100 px-6 pb-6 pt-4">
                  <p class="pl-9 text-[14.5px] leading-[1.8] text-ink-600">{item.a}</p>
                </div>
              </details>
            ))}
          </div>

        </div>
      </div>
    </section>
  )}


  <!-- ══════════════════════════════════════════════════════
       7. SERVICIOS RELACIONADOS — navegar a los otros 3
       ══════════════════════════════════════════════════════ -->
  <section class="section-white">
    <div class="container">
      <div class="mb-10 flex items-end justify-between gap-4">
        <div>
          <span class="eyebrow">Más servicios</span>
          <h2 class="heading-md mt-4">Otros servicios <span class="text-accent-500">relacionados</span></h2>
          <span class="marker-line mt-5"></span>
        </div>
        <a href="/servicios/" class="btn-outline hidden sm:inline-flex shrink-0">Ver todos</a>
      </div>

      <div class="grid gap-5 sm:grid-cols-3">
        {[
          { href: '/servicios/hogar/',         label: 'Cámaras para Hogar',    eyebrow: 'Residencial',    icon: 'home',    color: 'brand' },
          { href: '/servicios/comercio/',       label: 'Cámaras para Comercio', eyebrow: 'Comercial',     icon: 'store',   color: 'accent' },
          { href: '/servicios/industrial/',     label: 'Sistemas Industriales', eyebrow: 'Industrial',    icon: 'factory', color: 'brand' },
          { href: '/servicios/control-acceso/', label: 'Control de Acceso',     eyebrow: 'Complementario', icon: 'lock',   color: 'accent' },
        ]
        .filter((rel) => rel.href !== `/servicios/${slug}/`)
        .map((rel) => {
          const relBg = rel.color === 'brand' ? 'bg-brand-500' : 'bg-accent-500';
          return (
            <a href={rel.href} class="card group flex items-center gap-4 p-5 transition-all hover:-translate-y-0.5 hover:shadow-card">
              <span class={`grid h-12 w-12 shrink-0 place-items-center rounded-xl ${relBg}`}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white" aria-hidden="true" set:html={svgIcons[rel.icon] ?? ''}/>
              </span>
              <div class="min-w-0">
                <p class="text-[11px] font-bold uppercase tracking-wider text-ink-400">{rel.eyebrow}</p>
                <p class="mt-0.5 font-bold text-ink-800 transition-colors group-hover:text-brand-500">{rel.label}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-auto h-4 w-4 shrink-0 text-ink-200 transition-all group-hover:translate-x-0.5 group-hover:text-accent-500" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          );
        })}
      </div>

      <a href="/servicios/" class="mt-6 flex items-center justify-center sm:hidden btn-outline w-full">Ver todos los servicios</a>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════
       8. CTA FINAL
       ══════════════════════════════════════════════════════ -->
  <CTASection />

</BaseLayout>

<style>
  /* Quita el marcador nativo del summary */
  details summary::-webkit-details-marker { display: none; }
  details summary::marker               { display: none; }

  /* Animación suave al abrir el details */
  details[open] .faq-body { animation: slide-down 0.2s ease; }
  @keyframes slide-down {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .faq-item[open] > summary {
    color: rgb(var(--color-brand));
  }
</style>
