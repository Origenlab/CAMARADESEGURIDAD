---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import RelatedLinks from '@components/RelatedLinks.astro';
import { SITE } from '@/consts';
import { getQuickLinks } from '@/data/seo';

export async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map((s) => ({
    params: { slug: s.id.replace(/\.md$/, '') },
    props: { servicio: s },
  }));
}

const { servicio } = Astro.props;
const { data: s } = servicio;
const slug = servicio.id.replace(/\.md$/, '');

const isBrand   = s.color === 'brand';
const accentHex = isBrand ? '#0A2540' : '#DC2626';

const breadcrumb = [
  { name: 'Inicio',    url: '/' },
  { name: 'Servicios', url: '/servicios/' },
  { name: s.shortTitle ?? s.title, url: `/servicios/${slug}/` },
];

const faqSchema = s.faq.map((f) => ({ q: f.q, a: f.a }));

// Products schema para los paquetes de ESTE servicio
const productsSchema = (s.paquetes ?? [])
  .map((pkg) => ({
    name: `${pkg.name} — ${s.title}`,
    description: pkg.detail,
    ...(pkg.precio !== undefined && { price: pkg.precio }),
    priceCurrency: 'MXN',
    brand: 'Cámara de Seguridad',
    category: s.title,
    url: `/servicios/${slug}/#paquetes`,
  }))
  .filter((p) => p.price !== undefined);

// Service schema para esta página
const serviceSchema = [
  {
    name: s.title,
    description: s.description,
    url: `/servicios/${slug}/`,
    serviceType: s.title,
  },
];

// SEO meta optimizado por slug
const seoTitle = s.seo?.title ?? `${s.title} | Instalación CCTV Profesional · Garantía 2 Años`;
const seoDesc = s.seo?.description ?? `${s.description} Visita técnica gratuita en CDMX y Edomex. Técnicos certificados Hikvision y Dahua, garantía 2 años por escrito.`;
const seoKeywords = `${s.title.toLowerCase()}, cámaras de seguridad ${slug}, instalación CCTV ${slug}, ${s.shortTitle?.toLowerCase() ?? ''}, Hikvision, Dahua, cotización gratis`;

// ── Iconos SVG paths ───────────────────────────────────────────
const svgIcons: Record<string, string> = {
  home:        '<path d="m3 11 9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V11Z"/><path d="M9 22V12h6v10"/>',
  store:       '<path d="M3 9h18l-1.5 11a2 2 0 0 1-2 1.7H6.5a2 2 0 0 1-2-1.7L3 9Z"/><path d="M3 9 5 4h14l2 5"/><path d="M9 13a3 3 0 1 0 6 0"/>',
  factory:     '<path d="M3 22V9l6 4V9l6 4V3h6v19H3Z"/><path d="M7 17h2M11 17h2M15 17h2"/>',
  lock:        '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
  camera:      '<path d="M3 8a2 2 0 0 1 2-2h3l2-2h4l2 2h3a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z"/><circle cx="12" cy="13" r="4"/>',
  shield:      '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>',
  eye:         '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>',
  bell:        '<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>',
  wifi:        '<path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
  monitor:     '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>',
  car:         '<path d="M5 13l2-5h10l2 5"/><path d="M5 13v5h2v-2h10v2h2v-5z"/><circle cx="8" cy="16" r="1.5"/><circle cx="16" cy="16" r="1.5"/>',
  fingerprint: '<path d="M2 12C2 6.5 6.5 2 12 2a10 10 0 0 1 8 4"/><path d="M5 19.5C5.5 18 6 15 6 12c0-3.3 2.7-6 6-6 1.8 0 3.4.8 4.5 2"/><path d="M8 19a23 23 0 0 0 .5-5"/><path d="M12 19v-3.5c0-1.7 1.3-3 3-3"/><path d="M18 19c-.3-1-.5-2-.5-3.5"/><path d="M20 19c-.3-2.5-1.5-5-3-6.5"/>',
  tool:        '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  ptz:         '<circle cx="12" cy="12" r="9"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/><circle cx="12" cy="12" r="3"/>',
  thermal:     '<path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4 4 0 1 0 5 0Z"/>',
  lpr:         '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 2v5M8 2v5M2 12h20"/>',
};

// ── Color classes ──────────────────────────────────────────────
const headerBg   = isBrand ? 'bg-brand-500' : 'bg-accent-500';
const headerBg2  = isBrand ? 'bg-brand-600' : 'bg-accent-600';
const eyebrowCol = isBrand ? 'text-accent-400' : 'text-white/70';
const markerCol  = isBrand ? 'bg-accent-500'  : 'bg-white/50';
const badgeBg    = isBrand ? 'bg-brand-500 text-white' : 'bg-accent-500 text-white';
const btnPrimCol = isBrand ? 'btn-brand' : 'btn-primary';
const iconBg     = isBrand ? 'bg-brand-50 text-brand-500 group-hover/sub:bg-brand-500 group-hover/sub:text-white'
                           : 'bg-accent-50 text-accent-500 group-hover/sub:bg-accent-500 group-hover/sub:text-white';

// Formateo de precio MXN
const formatPrice = (n: number) =>
  new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', maximumFractionDigits: 0 }).format(n);
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  keywords={seoKeywords}
  canonical={`/servicios/${slug}/`}
  breadcrumb={breadcrumb}
  faq={faqSchema}
  services={serviceSchema}
  products={productsSchema}
>

  <!-- ══════════════════════════════════════════════════════
       1. HERO — componente unificado <Hero/> (mismo del Home)
       ══════════════════════════════════════════════════════ -->
  <Hero
    eyebrow={s.eyebrow}
    preTitle={s.hero?.preTitle ?? `Servicio ${s.shortTitle ?? ''}`}
    title1={s.hero?.title1 ?? s.title.split(' ').slice(0, -1).join(' ')}
    title2={s.hero?.title2 ?? s.title.split(' ').slice(-1).join(' ')}
    subtitle={s.subtitle}
    descriptionHtml={s.hero?.col2Paragraphs?.[0] ?? s.description}
    col2Eyebrow={s.hero?.col2Eyebrow ?? 'Por qué elegirnos'}
    col2Title={s.hero?.col2Title ?? 'Diseño profesional con '}
    col2TitleHighlight={s.hero?.col2TitleHighlight ?? 'garantía 2 años'}
    col2Paragraphs={(s.hero?.col2Paragraphs ?? [s.pilarIntro ?? s.descripcionLarga ?? s.description])
      .map((html) => ({ html }))}
    col2HighlightStat={s.hero?.col2HighlightStat}
    col2Features={(s.hero?.col2Features ?? []).map((text) => ({ text }))}
    col2TrustStrip={s.hero?.col2TrustStrip ?? []}
    quickLinks={getQuickLinks(`/servicios/${slug}/`)}
    showRecBadge={s.hero?.showRecBadge ?? true}
    showQuickLinks={true}
  />


  <!-- ══════════════════════════════════════════════════════
       2. DESCRIPCIÓN + PILAR INTRO — diseño profesional rediseñado
       ══════════════════════════════════════════════════════ -->
  <section class="section-white relative overflow-hidden">

    <!-- Círculo decorativo de fondo -->
    <div class="pointer-events-none absolute -right-32 top-1/3 -z-0 hidden lg:block" aria-hidden="true">
      <div class={`h-[480px] w-[480px] rounded-full opacity-[0.035] ${isBrand ? 'bg-brand-500' : 'bg-accent-500'}`}></div>
    </div>

    <div class="container relative">

      <!-- HEADER DE SECCIÓN — SectionHeader canónico con 2 párrafos -->
      <SectionHeader
        eyebrow="Sobre este servicio"
        title={`${s.title} en detalle`}
        highlight="en detalle"
        titleBreakBefore={true}
        lead={s.seccionIntro && s.seccionIntro.length > 0 ? s.seccionIntro : [s.description]}
      />

      <!-- GRID PRINCIPAL — 50/50 equilibrado · ambas cols mismo alto -->
      <div class="mt-14 grid gap-10 lg:grid-cols-2 lg:gap-12 lg:items-stretch">

        <!-- ── COLUMNA IZQUIERDA — descripción + stats + 2do párrafo ── -->
        <div class="flex flex-col">
          <!-- Drop-cap en primer párrafo -->
          <p class="text-[16.5px] leading-[1.85] text-ink-700 first-letter:float-left first-letter:mr-3 first-letter:mt-1.5 first-letter:font-display first-letter:text-[68px] first-letter:font-black first-letter:leading-none first-letter:text-accent-500">
            {s.descripcionLarga ?? s.description}
          </p>

          <!-- Mini stats band inline -->
          {s.miniStats && s.miniStats.length > 0 && (
            <div class={`mt-8 grid divide-x divide-cream-300 overflow-hidden rounded-2xl border border-cream-300 bg-gradient-to-br from-white to-cream-50 ${s.miniStats.length === 4 ? 'grid-cols-2 sm:grid-cols-4 divide-y sm:divide-y-0' : 'grid-cols-3 divide-y-0'}`}>
              {s.miniStats.map((st) => (
                <div class="flex flex-col items-start gap-1 px-5 py-4">
                  <p class={`font-display text-2xl font-black leading-none ${isBrand ? 'text-brand-500' : 'text-accent-500'} sm:text-[28px]`}>
                    {st.value}
                  </p>
                  <p class="text-[10.5px] font-bold uppercase tracking-wider text-ink-500 leading-tight">
                    {st.label}
                  </p>
                </div>
              ))}
            </div>
          )}

          <!-- Segundo párrafo (descripcionSecundaria) -->
          {s.descripcionSecundaria && (
            <p class="mt-8 text-[16px] leading-[1.85] text-ink-700" set:html={s.descripcionSecundaria}></p>
          )}

          <!-- ── BLOQUE COMPROMISO — 3 mini info cards horizontales ── -->
          <div class="mt-8 grid grid-cols-3 gap-3">
            <div class="rounded-xl border border-cream-200 bg-white p-4">
              <span class={`flex h-9 w-9 items-center justify-center rounded-lg ${isBrand ? 'bg-brand-500/8 text-brand-500' : 'bg-accent-500/8 text-accent-500'}`}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                </svg>
              </span>
              <p class="mt-3 font-display text-[15px] font-black text-brand-500 leading-tight">Visita técnica</p>
              <p class="mt-1 text-[12px] text-ink-500 leading-snug">Gratis · 24-48 h</p>
            </div>

            <div class="rounded-xl border border-cream-200 bg-white p-4">
              <span class={`flex h-9 w-9 items-center justify-center rounded-lg ${isBrand ? 'bg-brand-500/8 text-brand-500' : 'bg-accent-500/8 text-accent-500'}`}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>
                </svg>
              </span>
              <p class="mt-3 font-display text-[15px] font-black text-brand-500 leading-tight">Garantía</p>
              <p class="mt-1 text-[12px] text-ink-500 leading-snug">2 años · por escrito</p>
            </div>

            <div class="rounded-xl border border-cream-200 bg-white p-4">
              <span class={`flex h-9 w-9 items-center justify-center rounded-lg ${isBrand ? 'bg-brand-500/8 text-brand-500' : 'bg-accent-500/8 text-accent-500'}`}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/>
                </svg>
              </span>
              <p class="mt-3 font-display text-[15px] font-black text-brand-500 leading-tight">Soporte WA</p>
              <p class="mt-1 text-[12px] text-ink-500 leading-snug">Respuesta &lt; 15 min</p>
            </div>
          </div>

          <!-- ── TESTIMONIO DESTACADO ── -->
          <figure class={`mt-6 relative overflow-hidden rounded-2xl border-l-4 ${isBrand ? 'border-brand-500' : 'border-accent-500'} bg-gradient-to-br from-cream-50 to-white p-6`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class={`absolute right-4 top-3 h-10 w-10 ${isBrand ? 'text-brand-500/8' : 'text-accent-500/8'}`} aria-hidden="true">
              <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
            </svg>
            <blockquote class="relative">
              <p class="text-[14.5px] leading-[1.7] text-ink-700 italic">
                "CAMSEG nos diseñó un sistema de 8 cámaras para la casa con cableado oculto perfecto. El técnico llegó puntual, capacitó a toda la familia con la app y a 18 meses sigue funcionando impecable. La cotización fue exactamente lo que pagamos — sin sorpresas."
              </p>
              <figcaption class="mt-4 flex items-center gap-3 border-t border-cream-200 pt-4">
                <span class={`flex h-9 w-9 shrink-0 items-center justify-center rounded-full font-display text-[13px] font-black text-white ${isBrand ? 'bg-brand-500' : 'bg-accent-500'}`}>
                  RM
                </span>
                <div>
                  <p class="font-display text-[13px] font-black text-brand-500 leading-tight">Roberto M.</p>
                  <p class="text-[11.5px] text-ink-500 leading-tight">Casa · Coyoacán, CDMX · cliente verificado</p>
                </div>
                <div class="ml-auto flex gap-0.5">
                  {[1,2,3,4,5].map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5 text-amber-400" aria-hidden="true">
                      <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z" clip-rule="evenodd"/>
                    </svg>
                  ))}
                </div>
              </figcaption>
            </blockquote>
          </figure>

          <!-- ── MARCAS CERTIFICADAS ── -->
          <div class="mt-6 flex flex-wrap items-center gap-3 border-t border-cream-200 pt-6">
            <p class="text-[10.5px] font-bold uppercase tracking-[0.22em] text-ink-400">
              Marcas certificadas
            </p>
            {['Hikvision', 'Dahua', 'Provision-ISR', 'Axis'].map((brand) => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-cream-300 bg-white px-3 py-1.5 text-[11.5px] font-bold uppercase tracking-wide text-brand-500 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 text-accent-500" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                {brand}
              </span>
            ))}
          </div>
        </div>

        <!-- ── COLUMNA DERECHA — pilar card destacada · full height ── -->
        {s.pilarIntro && (
          <aside class="flex">
            <div class={`relative overflow-hidden rounded-3xl ${headerBg} text-white shadow-[0_24px_60px_-20px_rgba(10,37,64,0.5)] w-full flex flex-col`}>

              <!-- Número decorativo grande -->
              <span class="absolute right-6 top-2 font-display text-[140px] font-black leading-none text-white/[0.06] select-none pointer-events-none" aria-hidden="true">
                01
              </span>

              <!-- Patrón de puntos sutil -->
              <div class="absolute inset-0 opacity-[0.05]" aria-hidden="true"
                style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>

              <!-- Borde accent superior -->
              <div class={`absolute left-0 top-0 h-1 w-full ${isBrand ? 'bg-accent-500' : 'bg-white/30'}`} aria-hidden="true"></div>

              <div class="relative flex flex-1 flex-col p-8 lg:p-9">

                <!-- Icon tile -->
                <span class="grid h-14 w-14 shrink-0 place-items-center rounded-2xl bg-white/15 ring-1 ring-white/20 backdrop-blur-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7 text-white" aria-hidden="true" set:html={svgIcons[s.icon] ?? svgIcons.camera}/>
                </span>

                <!-- Título canónico (eyebrow-light + heading-light + marker-line accent) -->
                <span class="eyebrow-light mt-5 block">El diferenciador</span>
                <h3 class="heading-md heading-light mt-4 text-balance">
                  Por qué <span class="text-accent-400">elegirnos</span>.
                </h3>
                <span class="marker-line mt-5" style="background-color: rgb(var(--color-accent))"></span>

                <!-- Pilar intro -->
                <p class="mt-5 text-[15px] leading-[1.8] text-white/90">
                  {s.pilarIntro}
                </p>

                <!-- Features con divider -->
                {s.features.length > 0 && (
                  <>
                    <div class="my-7 h-px bg-white/15"></div>
                    <span class="eyebrow-light">Incluido sin costo extra</span>
                    <ul class="mt-5 space-y-3">
                      {s.features.map((f) => (
                        <li class="flex items-start gap-3 text-[13.5px] leading-snug text-white/90">
                          <span class={`mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full ${isBrand ? 'bg-accent-500' : 'bg-white/25'}`}>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3 text-white" aria-hidden="true">
                              <path d="M20 6 9 17l-5-5"/>
                            </svg>
                          </span>
                          <span>{f}</span>
                        </li>
                      ))}
                    </ul>
                  </>
                )}

                <!-- CTA WhatsApp al pie -->
                <a
                  href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, me interesa cotizar el servicio: ${s.title}`)}`}
                  target="_blank"
                  rel="noopener"
                  class="mt-8 flex items-center justify-center gap-2.5 rounded-xl bg-white px-6 py-3.5 font-display text-[14px] font-bold transition-all hover:-translate-y-0.5 hover:shadow-xl active:scale-95"
                  style={`color: ${accentHex}`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/>
                  </svg>
                  Cotizar este servicio
